{
  "$defs": {
    "JsonValue": {},
    "TransactionStatus": {
      "enum": [
        "prepared",
        "completed"
      ],
      "title": "TransactionStatus",
      "type": "string"
    }
  },
  "$id": "urn:cranfield:pilot-assessment:schema:transaction-receipt:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "audit_event_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Audit Event Id"
    },
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Completed At"
    },
    "contract_id": {
      "const": "transaction-receipt",
      "default": "transaction-receipt",
      "title": "Contract Id",
      "type": "string"
    },
    "contract_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "method": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Method",
      "type": "string"
    },
    "request_hash": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[0-9A-Fa-f]{64}$",
      "title": "Request Hash",
      "type": "string"
    },
    "response_payload": {
      "anyOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "title": "Response Payload"
    },
    "status": {
      "$ref": "#/$defs/TransactionStatus"
    },
    "transaction_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Transaction Id",
      "type": "string"
    }
  },
  "required": [
    "transaction_id",
    "method",
    "request_hash",
    "status",
    "response_payload",
    "audit_event_id",
    "completed_at"
  ],
  "title": "Pilot Assessment Transaction Receipt 0.1.0",
  "type": "object",
  "x-contract-version": "0.1.0",
  "x-runtime-invariants": [
    "prepared and completed transactions use mutually exclusive field shapes"
  ]
}
