  "$id": "urn:cranfield:pilot-assessment:schema:session-manifest:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "annotations": {
      "$ref": "#/$defs/AnnotationReferences"
    },
    "bundle_schema_version": {
      "pattern": "^0\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
      "title": "Bundle Schema Version",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Extensions",
      "type": "object"
    },
    "integrity": {
      "$ref": "#/$defs/IntegrityDefinition"
    },
    "participant": {
      "$ref": "#/$defs/Participant"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyDefinition"
    },
    "session_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Session Id",
      "type": "string"
    },
    "session_timebase": {
      "$ref": "#/$defs/SessionTimebase"
    },
    "source_session": {
      "$ref": "#/$defs/SourceSession"
    },
    "streams": {
      "allOf": [
        {
          "required": [
            "ECG",
            "EEG",
            "G",
            "I",
            "U",
            "X",
            "pilot_camera"
          ]
        },
        {
          "not": {
            "required": [
              "P"
            ]
          }
        }
      ],
      "patternProperties": {
        "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$": {
          "$ref": "#/$defs/StreamDescriptor"
        }
      },
      "propertyNames": {
        "maxLength": 128,
        "minLength": 1
      },
      "title": "Streams",
      "type": "object",
      "x-core-modalities": [
        "ECG",
        "EEG",
        "G",
        "I",
        "U",
        "X",
        "pilot_camera"
      ],
      "x-optional-stream-policy": "same-major optional stable stream IDs are preserved"
    },
    "task": {
      "$ref": "#/$defs/TaskDefinition"
    }
  },
  "required": [
    "bundle_schema_version",
    "session_id",
    "created_at",
    "source_session",
    "participant",
    "task",
    "session_timebase",
    "streams",
    "annotations",
    "integrity",
    "privacy"
  ],
  "title": "Pilot Assessment Session Manifest 0.1.0",
  "type": "object",
  "x-contract-version": "0.1.0",
  "x-runtime-invariants": [
    "stream map key must equal descriptor.modality",
    "present stream checksum keys must exactly match paths",
    "declared paths are unique under Windows case folding",
    "bundle_schema_version major must be supported by the reader"
  ]
}
