          "if": {
            "properties": {
              "status": {
                "const": "present"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "clock_sync": {
                "not": {
                  "type": "null"
                }
              },
              "paths": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "export_pending"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
