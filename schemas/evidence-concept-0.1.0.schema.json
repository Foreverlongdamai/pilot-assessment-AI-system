{
  "$defs": {
    "ComponentLifecycle": {
      "enum": [
        "active",
        "archived",
        "retired"
      ],
      "title": "ComponentLifecycle",
      "type": "string"
    }
  },
  "$id": "urn:cranfield:pilot-assessment:schema:evidence-concept:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "concept_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Concept Id",
      "type": "string"
    },
    "contract_id": {
      "const": "evidence-concept",
      "default": "evidence-concept",
      "title": "Contract Id",
      "type": "string"
    },
    "contract_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "description": {
      "maxLength": 8000,
      "title": "Description",
      "type": "string"
    },
    "lifecycle": {
      "$ref": "#/$defs/ComponentLifecycle"
    },
    "name": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "tags": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    }
  },
  "required": [
    "concept_id",
    "name",
    "description",
    "tags",
    "lifecycle"
  ],
  "title": "Pilot Assessment Evidence Concept 0.1.0",
  "type": "object",
  "x-contract-version": "0.1.0",
  "x-runtime-invariants": [
    "concept IDs are immutable and tags are unique"
  ]
}
