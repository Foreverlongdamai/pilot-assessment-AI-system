      "required": [
        "modality",
        "channel_ids"
      ],
      "title": "BaselineChannelBinding",
      "type": "object"
    },
    "BaselineDefinition": {
      "additionalProperties": false,
      "properties": {
        "annotation_exclusion_reason": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
