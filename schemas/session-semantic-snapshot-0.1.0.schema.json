        "geometry_kind": {
          "$ref": "#/$defs/AoiGeometryKind"
        },
        "off_task": {
          "title": "Off Task",
          "type": "boolean"
        },
        "priority": {
          "minimum": 0,
          "title": "Priority",
          "type": "integer"
        },
        "role": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Role",
          "type": "string"
        },
        "role_weight": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Role Weight",
          "type": "number"
