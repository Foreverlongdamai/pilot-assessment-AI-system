    "ControlEffectMapping": {
      "additionalProperties": false,
      "properties": {
        "control_channel_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
