        "control_mapping_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Control Mapping Id",
          "type": "string"
        },
        "control_unit": {
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9%*/^._-]+$",
          "title": "Control Unit",
          "type": "string"
        },
        "correct_sign": {
          "enum": [
            -1,
            1
          ],
          "title": "Correct Sign",
          "type": "integer"
        },
        "lower": {
          "title": "Lower",
          "type": "number"
        },
        "state_axis_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "State Axis Id",
          "type": "string"
        },
        "state_unit": {
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9%*/^._-]+$",
          "title": "State Unit",
          "type": "string"
        },
        "trim": {
          "title": "Trim",
          "type": "number"
        },
        "upper": {
          "title": "Upper",
          "type": "number"
        }
