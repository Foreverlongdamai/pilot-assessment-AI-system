  "$id": "urn:cranfield:pilot-assessment:schema:anchor-result:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "else": {
        "properties": {
          "continuous_score": {
            "type": "null"
          },
          "evidence_likelihood": {
            "type": "null"
          },
          "evidence_state": {
            "type": "null"
          }
        }
      },
      "if": {
        "properties": {
          "calculation_status": {
            "const": "computed"
          }
        },
        "required": [
          "calculation_status"
        ]
      },
      "then": {
        "properties": {
          "continuous_score": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "evidence_likelihood": {
            "$ref": "#/$defs/EvidenceLikelihood"
          },
          "evidence_state": {
            "$ref": "#/$defs/EvidenceState"
          }
        }
      }
    }
  ],
  "properties": {
    "anchor_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Anchor Id",
      "type": "string"
    },
    "calculation_status": {
      "$ref": "#/$defs/CalculationStatus"
    },
    "continuous_score": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "title": "Continuous Score"
    },
    "dependencies": {
      "$ref": "#/$defs/Dependencies"
    },
    "derived_artifacts": {
      "items": {
        "$ref": "#/$defs/DerivedArtifact"
      },
      "title": "Derived Artifacts",
      "type": "array"
    },
    "diagnostics": {
      "items": {
        "$ref": "#/$defs/Diagnostic"
      },
      "title": "Diagnostics",
      "type": "array"
    },
    "event_results": {
      "items": {
        "$ref": "#/$defs/EventResult"
      },
      "title": "Event Results",
      "type": "array"
    },
    "evidence_likelihood": {
      "anyOf": [
        {
          "$ref": "#/$defs/EvidenceLikelihood"
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_state": {
      "anyOf": [
        {
          "$ref": "#/$defs/EvidenceState"
        },
        {
          "type": "null"
        }
      ]
    },
    "extensions": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Extensions",
      "type": "object"
    },
    "input_status_snapshot": {
      "patternProperties": {
        "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$": {
          "$ref": "#/$defs/StreamStatus"
        }
      },
      "propertyNames": {
        "maxLength": 128,
        "minLength": 1
      },
      "title": "Input Status Snapshot",
      "type": "object"
    },
    "model_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Model Version",
      "type": "string"
    },
    "parameter_hash": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[0-9A-Fa-f]{64}$",
      "title": "Parameter Hash",
      "type": "string"
    },
    "parameters_used": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Parameters Used",
      "type": "object"
    },
    "phase_results": {
      "patternProperties": {
        "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$": {
          "$ref": "#/$defs/EvidenceState"
        }
      },
      "propertyNames": {
        "maxLength": 128,
        "minLength": 1
      },
      "title": "Phase Results",
      "type": "object"
    },
    "primary_value": {
      "anyOf": [
        {
          "$ref": "#/$defs/PrimaryValue"
        },
        {
          "type": "null"
        }
      ]
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "quality": {
      "$ref": "#/$defs/AnchorQuality"
    },
    "raw_metrics": {
      "patternProperties": {
        "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$": {
          "type": "number"
        }
      },
      "propertyNames": {
        "maxLength": 128,
        "minLength": 1
      },
      "title": "Raw Metrics",
      "type": "object"
    },
    "source_windows": {
      "items": {
        "$ref": "#/$defs/SourceWindow"
      },
      "title": "Source Windows",
      "type": "array"
    },
    "thresholds_used": {
      "patternProperties": {
        "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$": {
          "type": "number"
        }
      },
      "propertyNames": {
        "maxLength": 128,
        "minLength": 1
      },
      "title": "Thresholds Used",
      "type": "object"
    }
  },
  "required": [
    "anchor_id",
    "model_version",
    "calculation_status",
    "evidence_state",
    "continuous_score",
    "evidence_likelihood",
    "raw_metrics",
    "primary_value",
    "phase_results",
    "event_results",
    "source_windows",
    "derived_artifacts",
    "quality",
    "thresholds_used",
    "parameters_used",
    "parameter_hash",
    "dependencies",
    "input_status_snapshot",
    "provenance",
    "diagnostics"
  ],
  "title": "Pilot Assessment Anchor Result 0.1.0",
  "type": "object",
  "x-contract-version": "0.1.0",
  "x-runtime-invariants": [
    "likelihood values sum to one within absolute tolerance 1e-9",
    "computed continuous_score equals ordinal_expectation_v1",
    "hard_threshold_v1 likelihood is one-hot and matches evidence_state",
    "soft likelihood ties declare an explicit tie_policy",
    "non-computed results omit all evidence observation fields",
    "binary_quality_v1 computed results have passed=true and score=1"
  ],
  "x-soft-tie-policies": [
    "prefer_adequate",
    "prefer_desired",
    "prefer_unacceptable"
  ]
}
