          "title": "Sample Ranges",
          "type": "array"
        },
        "source_files": {
          "items": {
            "maxLength": 1024,
            "minLength": 1,
            "pattern": "^(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*(?:^|/)[^/]*[. ](?:/|$))[^/\\\\:\\x00]+(?:/[^/\\\\:\\x00]+)*$",
            "type": "string",
            "x-runtime-invariants": [
              "segments are not empty, '.' or '..'",
              "segments do not end in a dot or space",
