          "title": "Extensions",
          "type": "object"
        },
        "raw_metrics": {
          "patternProperties": {
            "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$": {
              "type": "number"
            }
          },
          "propertyNames": {
            "maxLength": 128,
            "minLength": 1
          },
          "title": "Raw Metrics",
          "type": "object"
        }
      },
      "required": [
        "event_id",
        "evidence_state",
        "raw_metrics"
      ],
      "title": "EventResult",
      "type": "object"
    },
    "EvidenceLikelihood": {
      "additionalProperties": false,
      "properties": {
        "state_order": {
          "maxItems": 3,
          "minItems": 3,
          "prefixItems": [
            {
              "const": "unacceptable",
              "type": "string"
            },
            {
              "const": "adequate",
              "type": "string"
            },
            {
              "const": "desired",
              "type": "string"
            }
          ],
          "title": "State Order",
          "type": "array"
        },
        "values": {
          "maxItems": 3,
          "minItems": 3,
          "prefixItems": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            }
          ],
          "title": "Values",
          "type": "array"
        }
      },
      "required": [
        "state_order",
        "values"
      ],
      "title": "EvidenceLikelihood",
      "type": "object"
    },
    "EvidenceState": {
      "enum": [
        "unacceptable",
        "adequate",
        "desired"
      ],
      "title": "EvidenceState",
      "type": "string"
    },
    "JsonValue": {},
    "PrimaryValue": {
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Extensions",
          "type": "object"
        },
        "unit": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "value",
        "unit"
      ],
      "title": "PrimaryValue",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "evidence_grade": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Evidence Grade",
          "type": "string"
        },
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Extensions",
          "type": "object"
        },
        "extractor_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Extractor Version",
          "type": "string"
        },
        "sample_ranges": {
          "items": {
            "$ref": "#/$defs/SampleRange"
