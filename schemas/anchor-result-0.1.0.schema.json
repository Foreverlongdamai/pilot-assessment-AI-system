{
  "$defs": {
    "AnchorQuality": {
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Extensions",
          "type": "object"
        },
        "flags": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
            "type": "string"
          },
          "title": "Flags",
          "type": "array"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "sync_error_ms": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Sync Error Ms"
        },
        "valid_coverage": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Valid Coverage",
          "type": "number"
        }
      },
      "required": [
        "passed",
        "score",
        "valid_coverage",
        "sync_error_ms",
        "flags"
      ],
      "title": "AnchorQuality",
      "type": "object"
    },
    "CalculationStatus": {
      "enum": [
        "computed",
        "invalid_quality",
        "missing_input",
        "not_applicable",
        "not_computable",
        "dependency_missing",
        "extractor_error"
      ],
      "title": "CalculationStatus",
      "type": "string"
    },
    "Dependencies": {
      "additionalProperties": false,
      "properties": {
        "available": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
            "type": "string"
          },
          "title": "Available",
          "type": "array"
        },
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Extensions",
          "type": "object"
        },
        "missing": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
            "type": "string"
          },
          "title": "Missing",
          "type": "array"
        }
      },
      "required": [
        "available",
        "missing"
      ],
      "title": "Dependencies",
      "type": "object"
    },
    "DerivedArtifact": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "window_metric_trace"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "alignment": {
                "type": "string"
              },
              "min_valid_fraction": {
                "maximum": 1.0,
                "minimum": 0.0,
                "type": "number"
              },
              "partial_window_policy": {
                "type": "string"
              },
              "step_s": {
                "exclusiveMinimum": 0.0,
                "type": "number"
              },
              "window_grid_id": {
                "type": "string"
              },
              "window_length_s": {
                "exclusiveMinimum": 0.0,
                "type": "number"
              }
            },
            "required": [
              "window_grid_id",
              "window_length_s",
              "step_s",
              "alignment",
              "min_valid_fraction",
              "partial_window_policy"
            ]
          }
        }
      ],
      "properties": {
        "alignment": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alignment"
        },
        "artifact_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Extensions",
          "type": "object"
        },
        "kind": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Kind",
          "type": "string"
        },
        "min_valid_fraction": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min Valid Fraction"
        },
        "partial_window_policy": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Partial Window Policy"
        },
        "path": {
          "maxLength": 1024,
          "minLength": 1,
          "pattern": "^(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*(?:^|/)[^/]*[. ](?:/|$))[^/\\\\:\\x00]+(?:/[^/\\\\:\\x00]+)*$",
          "title": "Path",
          "type": "string",
          "x-runtime-invariants": [
            "segments are not empty, '.' or '..'",
            "segments do not end in a dot or space",
            "resolved files remain below the owning artifact root"
          ]
        },
        "schema_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Schema Id",
          "type": "string"
        },
        "step_s": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Step S"
        },
        "window_grid_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Window Grid Id"
        },
        "window_length_s": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Window Length S"
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "path",
        "schema_id"
      ],
      "title": "DerivedArtifact",
      "type": "object"
    },
    "Diagnostic": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Code",
          "type": "string"
        },
        "details": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Details",
          "type": "object"
        },
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Extensions",
          "type": "object"
        },
        "field_or_path": {
          "anyOf": [
            {
              "maxLength": 2048,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Field Or Path"
        },
        "message": {
          "maxLength": 2048,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "remediation": {
          "anyOf": [
            {
              "maxLength": 2048,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Remediation"
        },
        "severity": {
          "$ref": "#/$defs/DiagnosticSeverity"
        }
      },
      "required": [
        "code",
        "severity",
        "message"
      ],
      "title": "Diagnostic",
      "type": "object"
    },
    "DiagnosticSeverity": {
      "enum": [
        "info",
        "warning",
        "error",
        "fatal"
      ],
      "title": "DiagnosticSeverity",
      "type": "string"
    },
    "EventResult": {
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Event Id",
          "type": "string"
        },
        "evidence_state": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceState"
            },
            {
              "type": "null"
            }
          ]
        },
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
