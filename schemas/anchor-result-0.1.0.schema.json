      "type": "object"
    },
    "SampleRange": {
      "additionalProperties": false,
      "properties": {
        "end_index": {
          "minimum": 0,
          "title": "End Index",
          "type": "integer"
        },
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Extensions",
          "type": "object"
        },
        "source_file": {
          "maxLength": 1024,
          "minLength": 1,
          "pattern": "^(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*(?:^|/)[^/]*[. ](?:/|$))[^/\\\\:\\x00]+(?:/[^/\\\\:\\x00]+)*$",
          "title": "Source File",
          "type": "string",
          "x-runtime-invariants": [
            "segments are not empty, '.' or '..'",
            "segments do not end in a dot or space",
            "resolved files remain below the owning artifact root"
          ]
        },
        "start_index": {
          "minimum": 0,
          "title": "Start Index",
          "type": "integer"
        }
      },
      "required": [
        "source_file",
        "start_index",
        "end_index"
      ],
      "title": "SampleRange",
      "type": "object"
    },
    "SourceWindow": {
      "additionalProperties": false,
      "properties": {
        "end_t_ns": {
          "maximum": 9223372036854775807,
          "minimum": 0,
          "title": "End T Ns",
          "type": "integer"
        },
        "event_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Id"
        },
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Extensions",
          "type": "object"
        },
        "phase": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Phase"
        },
        "start_t_ns": {
          "maximum": 9223372036854775807,
          "minimum": 0,
          "title": "Start T Ns",
          "type": "integer"
        }
