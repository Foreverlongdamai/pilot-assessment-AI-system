{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pilot-assessment-document-metadata-v1",
  "title": "Pilot Assessment manual Markdown metadata",
  "type": "object",
  "required": [
    "document_id", "language", "title", "short_title", "product_version",
    "document_version", "status", "audience", "information_types",
    "scope", "prerequisites", "scientific_status", "related_documents", "support",
    "release_channel", "release_label", "user_acceptance"
  ],
  "properties": {
    "document_id": {"type": "string", "pattern": "^PAS-[A-Z-]+-[0-9]{3}$"},
    "language": {"enum": ["zh-CN", "en-GB"]},
    "title": {"type": "string", "minLength": 1},
    "short_title": {"type": "string", "minLength": 1},
    "product_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "document_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"enum": ["draft", "review", "released", "superseded"]},
    "audience": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["evaluator", "expert", "developer", "maintainer", "release"]}},
    "information_types": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["tutorial", "how-to", "reference", "explanation"]}},
    "scope": {"type": "string", "minLength": 1},
    "prerequisites": {"type": "array", "items": {"type": "string"}},
    "scientific_status": {"enum": ["engineering-only", "expert-reviewed", "calibrated"]},
    "related_documents": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^PAS-[A-Z-]+-[0-9]{3}$"}},
    "support": {"type": "string", "minLength": 1},
    "release_channel": {"enum": ["release-candidate", "final"]},
    "release_label": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-rc\\.[0-9]+)?$"
    },
    "user_acceptance": {
      "enum": [
        "pending",
        "accepted",
        "accepted-with-documentation-only-corrections",
        "changes-required"
      ]
    }
  },
  "additionalProperties": false
}
