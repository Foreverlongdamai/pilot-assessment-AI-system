<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.TaskSchemeSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:PilotAssessment.Desktop.Core.ViewModels">
    <Grid MinWidth="280" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Task schemes" />
            <TextBlock
                Opacity="0.68"
                Text="Parallel task configurations; switching does not mutate the model."
                TextWrapping="Wrap" />
        </StackPanel>

        <CommandBar
            Grid.Row="1"
            Margin="-12,8,-8,2"
            Background="Transparent"
            DefaultLabelPosition="Collapsed"
            IsDynamicOverflowEnabled="True">
            <AppBarButton
                AutomationProperties.Name="Create task scheme"
                Click="OnCreateClick"
                Label="New">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="Copy selected task scheme"
                Click="OnCopyClick"
                IsEnabled="{x:Bind ViewModel.CanMutate, Mode=OneWay}"
                Label="Copy">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8C8;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="Rename selected task scheme"
                Click="OnRenameClick"
                IsEnabled="{x:Bind ViewModel.CanMutate, Mode=OneWay}"
                Label="Rename">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8AC;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="Archive selected task scheme"
                Click="OnArchiveClick"
                IsEnabled="{x:Bind ViewModel.CanMutate, Mode=OneWay}"
                Label="Archive">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7B8;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <TextBox
            Grid.Row="2"
            Margin="0,0,0,10"
            AutomationProperties.Name="Search task schemes"
            PlaceholderText="Search name, ID, tag or group"
            TextChanged="OnSearchTextChanged">
            <TextBox.Header>
                <TextBlock Text="Find" />
            </TextBox.Header>
        </TextBox>

        <Grid Grid.Row="3" Margin="0,0,0,10" ColumnSpacing="8" RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ComboBox
                Header="Group"
                ItemsSource="{x:Bind ViewModel.AvailableGroups}"
                SelectedItem="{x:Bind ViewModel.SelectedGroupFilter, Mode=TwoWay}" />
            <ComboBox
                Grid.Column="1"
                Header="Tag"
                ItemsSource="{x:Bind ViewModel.AvailableTags}"
                SelectedItem="{x:Bind ViewModel.SelectedTagFilter, Mode=TwoWay}" />
            <ComboBox
                Grid.Row="1"
                Header="Sort"
                ItemsSource="{x:Bind ViewModel.SortOptions}"
                SelectedItem="{x:Bind ViewModel.SelectedSort, Mode=TwoWay}" />
            <ToggleSwitch
                Grid.Row="1"
                Grid.Column="1"
                Header="Lifecycle"
                IsOn="{x:Bind ViewModel.ShowArchived, Mode=TwoWay}"
                OffContent="Active"
                OnContent="Include archived" />
        </Grid>

        <ListView
            x:Name="SchemeList"
            Grid.Row="4"
            AutomationProperties.Name="Task scheme list"
            IsItemClickEnabled="True"
            ItemsSource="{x:Bind ViewModel.Schemes}"
            SelectedItem="{x:Bind ViewModel.SelectedScheme, Mode=OneWay}"
            SelectionChanged="OnSchemeSelectionChanged"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:TaskSchemeListItemViewModel">
                    <Grid Padding="4,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="2" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind DisplayName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="12"
                                Opacity="0.72"
                                Text="{x:Bind StatusLine}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="11"
                                Opacity="0.58"
                                Text="{x:Bind ClassificationLine}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="5" Margin="0,10,0,0" Spacing="6">
            <ProgressBar IsIndeterminate="True" Visibility="{x:Bind ViewModel.IsBusy}" />
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error" />
            <TextBlock
                FontSize="12"
                Opacity="0.68"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
