<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.TaskSchemeSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:PilotAssessment.Desktop.Core.ViewModels">
    <Grid MinWidth="280" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Task_Title], Source={StaticResource Localization}}" />
            <TextBlock
                Opacity="0.68"
                Text="{Binding [Task_Subtitle], Source={StaticResource Localization}}"
                TextWrapping="Wrap" />
        </StackPanel>

        <CommandBar
            Grid.Row="1"
            Margin="-12,8,-8,2"
            Background="Transparent"
            DefaultLabelPosition="Collapsed"
            IsDynamicOverflowEnabled="True">
            <AppBarButton
                AutomationProperties.Name="{Binding [Task_CreateA11y], Source={StaticResource Localization}}"
                Click="OnCreateClick"
                Label="{Binding [Common_New], Source={StaticResource Localization}}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="{Binding [Task_CopyA11y], Source={StaticResource Localization}}"
                Click="OnCopyClick"
                IsEnabled="{x:Bind ViewModel.CanMutate, Mode=OneWay}"
                Label="{Binding [Common_Copy], Source={StaticResource Localization}}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8C8;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="{Binding [Task_RenameA11y], Source={StaticResource Localization}}"
                Click="OnRenameClick"
                IsEnabled="{x:Bind ViewModel.CanMutate, Mode=OneWay}"
                Label="{Binding [Common_Rename], Source={StaticResource Localization}}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8AC;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="{Binding [Task_ArchiveA11y], Source={StaticResource Localization}}"
                Click="OnArchiveClick"
                IsEnabled="{x:Bind ViewModel.CanMutate, Mode=OneWay}"
                Label="{Binding [Common_Archive], Source={StaticResource Localization}}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE7B8;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <TextBox
            Grid.Row="2"
            Margin="0,0,0,10"
            AutomationProperties.Name="{Binding [Task_SearchA11y], Source={StaticResource Localization}}"
            PlaceholderText="{Binding [Task_SearchPlaceholder], Source={StaticResource Localization}}"
            TextChanged="OnSearchTextChanged">
            <TextBox.Header>
                <TextBlock Text="{Binding [Common_Find], Source={StaticResource Localization}}" />
            </TextBox.Header>
        </TextBox>

        <Grid Grid.Row="3" Margin="0,0,0,10" ColumnSpacing="8" RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ComboBox
                Header="{Binding [Common_Group], Source={StaticResource Localization}}"
                ItemsSource="{x:Bind ViewModel.AvailableGroups}"
                SelectedItem="{x:Bind ViewModel.SelectedGroupFilter, Mode=TwoWay}" />
            <ComboBox
                Grid.Column="1"
                Header="{Binding [Common_Tag], Source={StaticResource Localization}}"
                ItemsSource="{x:Bind ViewModel.AvailableTags}"
                SelectedItem="{x:Bind ViewModel.SelectedTagFilter, Mode=TwoWay}" />
            <ComboBox
                Grid.Row="1"
                Header="{Binding [Common_Sort], Source={StaticResource Localization}}"
                ItemsSource="{x:Bind ViewModel.SortOptions}"
                SelectedItem="{x:Bind ViewModel.SelectedSort, Mode=TwoWay}" />
            <ToggleSwitch
                Grid.Row="1"
                Grid.Column="1"
                Header="{Binding [Common_Lifecycle], Source={StaticResource Localization}}"
                IsOn="{x:Bind ViewModel.ShowArchived, Mode=TwoWay}"
                OffContent="{Binding [Common_Active], Source={StaticResource Localization}}"
                OnContent="{Binding [Common_IncludeArchived], Source={StaticResource Localization}}" />
        </Grid>

        <ListView
            x:Name="SchemeList"
            Grid.Row="4"
            AutomationProperties.Name="{Binding [Task_ListA11y], Source={StaticResource Localization}}"
            IsItemClickEnabled="True"
            ItemsSource="{x:Bind ViewModel.Schemes}"
            SelectedItem="{x:Bind ViewModel.SelectedScheme, Mode=OneWay}"
            SelectionChanged="OnSchemeSelectionChanged"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:TaskSchemeListItemViewModel">
                    <Grid Padding="4,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="2" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{x:Bind DisplayName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="12"
                                Opacity="0.72"
                                Text="{x:Bind StatusLine}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="11"
                                Opacity="0.58"
                                Text="{x:Bind ClassificationLine}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="5" Margin="0,10,0,0" Spacing="6">
            <ProgressBar IsIndeterminate="True" Visibility="{x:Bind ViewModel.IsBusy}" />
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error" />
            <TextBlock
                FontSize="12"
                Opacity="0.68"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
