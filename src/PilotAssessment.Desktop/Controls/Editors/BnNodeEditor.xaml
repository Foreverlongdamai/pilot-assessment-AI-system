<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Editors.BnNodeEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editors="using:PilotAssessment.Desktop.Controls.Editors">
    <StackPanel Spacing="12">
        <InfoBar
            IsClosable="False"
            IsOpen="True"
            Message="{Binding StatusMessage}"
            Severity="Informational"
            Title="{Binding [Bn_CanonicalEditor], Source={StaticResource Localization}}" />
        <InfoBar
            x:Name="ErrorBar"
            IsClosable="True"
            IsOpen="False"
            Severity="Error"
            Title="{Binding [Bn_OperationBlocked], Source={StaticResource Localization}}" />

        <TabView MinHeight="640">
            <TabViewItem Header="{Binding [Editor_General], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Header="{Binding [Editor_EnglishName], Source={StaticResource Localization}}" Text="{Binding NameEn, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Column="1" Header="{Binding [Editor_ChineseName], Source={StaticResource Localization}}" Text="{Binding NameZh, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="1" Header="{Binding [Editor_EnglishDescription], Source={StaticResource Localization}}" Text="{Binding DescriptionEn, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Row="1" Grid.Column="1" Header="{Binding [Editor_ChineseDescription], Source={StaticResource Localization}}" Text="{Binding DescriptionZh, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Row="2" Header="{Binding [Common_Group], Source={StaticResource Localization}}" Text="{Binding Group, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="2" Grid.Column="1" Header="{Binding [Editor_TagsSeparated], Source={StaticResource Localization}}" Text="{Binding TagsText, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <ComboBox Grid.Row="3" Header="{Binding [Bn_NodeRole], Source={StaticResource Localization}}" ItemsSource="{Binding NodeRoles}" SelectedItem="{Binding NodeRole, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                            <ComboBox Grid.Row="3" Grid.Column="1" Header="{Binding [Bn_ScientificStatus], Source={StaticResource Localization}}" ItemsSource="{Binding ScientificStatuses}" SelectedItem="{Binding ScientificStatus, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        </Grid>
                        <TextBox AcceptsReturn="True" Header="{Binding [Common_Documentation], Source={StaticResource Localization}}" MinHeight="110" Text="{Binding Documentation, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        <TextBox AcceptsReturn="True" Header="{Binding [Bn_ReportingMetadata], Source={StaticResource Localization}}" MinHeight="130" FontFamily="Consolas" Text="{Binding ReportingMetadataJson, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox AcceptsReturn="True" Header="{Binding [Editor_EnglishHelp], Source={StaticResource Localization}}" MinHeight="110" Text="{Binding HelpTextEn, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Column="1" AcceptsReturn="True" Header="{Binding [Editor_ChineseHelp], Source={StaticResource Localization}}" MinHeight="110" Text="{Binding HelpTextZh, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        </Grid>
                        <InfoBar IsClosable="False" IsOpen="True" Message="{Binding [Bn_SaveBoundaryDescription], Source={StaticResource Localization}}" Severity="Informational" Title="{Binding [Bn_SaveBoundary], Source={StaticResource Localization}}" />
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Bn_ParentsChildren], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="14">
                        <InfoBar IsClosable="False" IsOpen="True" Message="{Binding [Bn_ParentDirectionDescription], Source={StaticResource Localization}}" Severity="Informational" Title="{Binding [Bn_ParentDirection], Source={StaticResource Localization}}" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="210" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="{Binding [Bn_NewParent], Source={StaticResource Localization}}" DisplayMemberPath="Label" ItemsSource="{Binding ParentCandidates}" SelectedItem="{Binding SelectedParentCandidate, Mode=TwoWay}" />
                            <ComboBox Grid.Column="1" Header="{Binding [Bn_CptMigration], Source={StaticResource Localization}}" ItemsSource="{Binding AddParentStrategies}" SelectedItem="{Binding AddParentStrategy, Mode=TwoWay}" />
                            <Button Grid.Column="2" VerticalAlignment="Bottom" Click="OnAddParentClick" Content="{Binding [Bn_AddParent], Source={StaticResource Localization}}" />
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Header="{Binding [Bn_OrderedParent], Source={StaticResource Localization}}" DisplayMemberPath="Label" ItemsSource="{Binding Parents}" SelectedItem="{Binding SelectedParent, Mode=TwoWay}" />
                            <ComboBox Grid.Column="1" Header="{Binding [Bn_RemovalMigration], Source={StaticResource Localization}}" ItemsSource="{Binding RemoveParentStrategies}" SelectedItem="{Binding RemoveParentStrategy, Mode=TwoWay}" />
                            <TextBox Grid.Column="2" Header="{Binding [Bn_MarginalWeights], Source={StaticResource Localization}}" Text="{Binding MarginalWeightsText, Mode=TwoWay}" />
                            <Button Grid.Column="3" VerticalAlignment="Bottom" Click="OnMoveParentUpClick" Content="{Binding [Bn_MoveUp], Source={StaticResource Localization}}" />
                            <Button Grid.Column="4" VerticalAlignment="Bottom" Click="OnMoveParentDownClick" Content="{Binding [Bn_MoveDown], Source={StaticResource Localization}}" />
                            <Button Grid.Column="5" VerticalAlignment="Bottom" Click="OnRemoveParentClick" Content="{Binding [Bn_Remove], Source={StaticResource Localization}}" />
                        </Grid>
                        <TextBlock FontWeight="SemiBold" Text="{Binding [Bn_Children], Source={StaticResource Localization}}" />
                        <ListView MaxHeight="260" ItemsSource="{Binding Children}" />
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Bn_States], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="10">
                    <InfoBar IsClosable="False" IsOpen="True" Message="{Binding [Bn_StateMigrationDescription], Source={StaticResource Localization}}" Severity="Warning" Title="{Binding [Bn_StateMigration], Source={StaticResource Localization}}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnAddStateClick" Content="{Binding [Editor_AddState], Source={StaticResource Localization}}" />
                        <Button Click="OnRemoveStateClick" Content="{Binding [Editor_RemoveSelected], Source={StaticResource Localization}}" />
                        <Button Click="OnCommitStatesClick" Content="{Binding [Editor_CommitStates], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <ListView x:Name="StateList" ItemsSource="{Binding States}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Header="{Binding [Editor_StateId], Source={StaticResource Localization}}" Text="{Binding StateId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="OnFieldChanged" />
                                    <TextBox Grid.Column="1" Header="{Binding [Editor_Label], Source={StaticResource Localization}}" Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="OnFieldChanged" />
                                    <TextBox Grid.Column="2" Header="{Binding [Common_Description], Source={StaticResource Localization}}" Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </TabViewItem>

            <TabViewItem Header="{Binding [Bn_CptGenerator], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12" HorizontalScrollBarVisibility="Auto">
                    <editors:CptGridEditor x:Name="CptGrid" />
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Bn_PosteriorInfluence], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="10">
                    <InfoBar IsClosable="False" IsOpen="True" Message="{Binding PosteriorSummary}" Severity="Informational" Title="{Binding [Bn_ReadOnlyInference], Source={StaticResource Localization}}" />
                    <TextBlock Text="{Binding [Bn_NoRunResult], Source={StaticResource Localization}}" />
                </StackPanel>
            </TabViewItem>

            <TabViewItem Header="{Binding [Editor_UsedBySchemes], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="8">
                    <InfoBar IsClosable="False" IsOpen="True" Message="{Binding [Editor_SharedImpactDescription], Source={StaticResource Localization}}" Severity="Warning" Title="{Binding [Editor_SharedImpact], Source={StaticResource Localization}}" />
                    <ListView ItemsSource="{Binding UsedBySchemes}" />
                </StackPanel>
            </TabViewItem>

            <TabViewItem Header="{Binding [Editor_History], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="8">
                    <TextBlock Opacity="0.72" Text="{Binding [Editor_HistoryDescription], Source={StaticResource Localization}}" />
                    <ListView ItemsSource="{Binding HistoryItems}" />
                </StackPanel>
            </TabViewItem>
        </TabView>
    </StackPanel>
</UserControl>
