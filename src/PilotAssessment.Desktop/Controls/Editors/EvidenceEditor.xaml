<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Editors.EvidenceEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:editors="using:PilotAssessment.Desktop.Controls.Editors">
    <StackPanel Spacing="12">
        <InfoBar
            IsClosable="False"
            IsOpen="True"
            Message="{Binding StatusMessage}"
            Severity="Informational"
            Title="{Binding [Evidence_CanonicalEditor], Source={StaticResource Localization}}" />
        <InfoBar
            IsClosable="False"
            IsOpen="{Binding HasMissingOperators}"
            Message="{Binding MissingOperatorsText}"
            Severity="Error"
            Title="{Binding [Evidence_OperatorUnavailable], Source={StaticResource Localization}}" />

        <TabView MinHeight="600">
            <TabViewItem Header="{Binding [Editor_General], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Header="{Binding [Editor_CanonicalName], Source={StaticResource Localization}}" Text="{Binding Name, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Column="1" Header="{Binding [Editor_CanonicalDescription], Source={StaticResource Localization}}" Text="{Binding Description, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Opacity="0.68" Text="{Binding [Editor_CanonicalEnglishHint], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                            <TextBox Grid.Row="2" Header="{Binding [Common_Group], Source={StaticResource Localization}}" Text="{Binding Group, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="2" Grid.Column="1" Header="{Binding [Editor_TagsSeparated], Source={StaticResource Localization}}" Text="{Binding TagsText, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Header="{Binding [Evidence_AnchorName], Source={StaticResource Localization}}" Text="{Binding AnchorName, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Column="1" Header="{Binding [Evidence_AnchorDescription], Source={StaticResource Localization}}" Text="{Binding AnchorDescription, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        </Grid>
                        <TextBox AcceptsReturn="True" Header="{Binding [Evidence_RecipeSummary], Source={StaticResource Localization}}" MinHeight="100" Text="{Binding RecipeSummary, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        <StackPanel Spacing="8">
                            <TextBlock Opacity="0.68" Text="{Binding [Editor_CanonicalEnglishHint], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                            <TextBox AcceptsReturn="True" Header="{Binding [Editor_CanonicalHelp], Source={StaticResource Localization}}" MinHeight="120" Text="{Binding HelpText, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Evidence_RawBindings], Source={StaticResource Localization}}">
                <Grid Padding="4,12" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="{Binding [Evidence_FixedBindings], Source={StaticResource Localization}}" />
                        <TextBlock Opacity="0.68" Text="{Binding [Evidence_FixedBindingsDescription], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                        <ListView ItemsSource="{Binding RawBindings}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="{Binding [Evidence_RecipeOutputs], Source={StaticResource Localization}}" />
                        <ListView ItemsSource="{Binding OutputBindings}" />
                    </StackPanel>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="{Binding [Evidence_RecipeGraph], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12" HorizontalScrollBarVisibility="Auto">
                    <editors:OperatorGraphEditor x:Name="OperatorGraph" />
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Evidence_Parameters], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="10">
                        <TextBlock FontWeight="SemiBold" Text="{Binding [Evidence_SchemaParameters], Source={StaticResource Localization}}" />
                        <TextBlock Opacity="0.68" Text="{Binding [Evidence_SchemaParametersDescription], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                        <editors:SchemaParameterForm x:Name="ParameterEditor" />
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Evidence_ScoringTab], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="12">
                        <TextBlock Opacity="0.68" Text="{Binding [Evidence_ScoringDescription], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                        <TextBox AcceptsReturn="True" Header="{Binding [Evidence_ScoringJson], Source={StaticResource Localization}}" MinHeight="180" Text="{Binding ScoringJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        <TextBox AcceptsReturn="True" Header="{Binding [Evidence_ObservationMapping], Source={StaticResource Localization}}" MinHeight="180" Text="{Binding ObservationMappingJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        <TextBox AcceptsReturn="True" Header="{Binding [Evidence_ModalityWeights], Source={StaticResource Localization}}" MinHeight="120" Text="{Binding ModalityWeightsJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Evidence_ObservationStates], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="10">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Header="{Binding [Evidence_ObservationPolicy], Source={StaticResource Localization}}" ItemsSource="{Binding ObservationPolicies}" SelectedItem="{Binding ObservationPolicy, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        <Button Grid.Column="1" VerticalAlignment="Bottom" Click="OnAddStateClick" Content="{Binding [Editor_AddState], Source={StaticResource Localization}}" />
                        <Button Grid.Column="2" VerticalAlignment="Bottom" Click="OnRemoveStateClick" Content="{Binding [Editor_RemoveSelected], Source={StaticResource Localization}}" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnCommitStatesClick" Content="{Binding [Editor_CommitStates], Source={StaticResource Localization}}" />
                        <TextBlock VerticalAlignment="Center" Opacity="0.68" Text="{Binding [Editor_StateTransactionDescription], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <ListView x:Name="StateList" ItemsSource="{Binding ObservationStates}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Header="{Binding [Editor_StateId], Source={StaticResource Localization}}" Text="{Binding StateId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                                    <TextBox Grid.Column="1" Header="{Binding [Editor_Label], Source={StaticResource Localization}}" Text="{Binding Label, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                                    <TextBox Grid.Column="2" Header="{Binding [Common_Description], Source={StaticResource Localization}}" Text="{Binding Description, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </TabViewItem>

            <TabViewItem Header="{Binding [Evidence_ProbabilisticParents], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12" HorizontalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <InfoBar IsClosable="False" IsOpen="True" Message="{Binding [Evidence_ProbabilisticDescription], Source={StaticResource Localization}}" Severity="Informational" Title="{Binding [Evidence_CanonicalBnRelationship], Source={StaticResource Localization}}" />
                        <TextBlock FontWeight="SemiBold" Text="{Binding [Editor_FixedParents], Source={StaticResource Localization}}" />
                        <TextBlock Text="{Binding ProbabilisticParentsText}" TextWrapping="Wrap" />
                        <editors:CptGridEditor x:Name="EvidenceCptGrid" />
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Evidence_PreviewTrace], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="12">
                    <TextBlock Opacity="0.68" Text="{Binding [Evidence_PreviewDescription], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="OnPreviewClick" Content="{Binding [Evidence_RequestPreview], Source={StaticResource Localization}}" />
                        <Button Click="OnCancelPreviewClick" Content="{Binding [Common_Cancel], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <TextBlock FontFamily="Consolas" Text="{Binding PreviewSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </TabViewItem>

            <TabViewItem Header="{Binding [Editor_UsedBySchemes], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="8">
                    <InfoBar IsClosable="False" IsOpen="True" Message="{Binding [Editor_SharedImpactDescription], Source={StaticResource Localization}}" Severity="Warning" Title="{Binding [Editor_SharedImpact], Source={StaticResource Localization}}" />
                    <ListView ItemsSource="{Binding UsedBySchemes}" />
                </StackPanel>
            </TabViewItem>

            <TabViewItem Header="{Binding [Editor_History], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="8">
                    <TextBlock Opacity="0.68" Text="{Binding [Editor_HistoryDescription], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                    <ListView ItemsSource="{Binding HistoryItems}" />
                </StackPanel>
            </TabViewItem>
        </TabView>
    </StackPanel>
</UserControl>
