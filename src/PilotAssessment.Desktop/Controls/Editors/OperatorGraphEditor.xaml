<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Editors.OperatorGraphEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox
                x:Name="OperatorPicker"
                AutomationProperties.Name="{Binding [Operator_CatalogA11y], Source={StaticResource Localization}}"
                DisplayMemberPath="DisplayName"
                ItemsSource="{Binding OperatorOptions}"
                PlaceholderText="{Binding [Operator_ChooseInstalled], Source={StaticResource Localization}}"
                SelectedItem="{Binding SelectedOperator, Mode=TwoWay}" />
            <Button
                Grid.Column="1"
                AutomationProperties.Name="{Binding [Operator_AddA11y], Source={StaticResource Localization}}"
                Click="OnAddOperatorClick"
                Content="{Binding [Operator_Add], Source={StaticResource Localization}}" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="{Binding [Operator_Nodes], Source={StaticResource Localization}}" />
                <ListView
                    x:Name="NodeList"
                    AutomationProperties.Name="{Binding [Operator_NodesA11y], Source={StaticResource Localization}}"
                    ItemsSource="{Binding RecipeNodes}"
                    SelectionChanged="OnNodeSelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="4" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                <TextBlock Opacity="0.68" Text="{Binding NodeId}" TextWrapping="Wrap" />
                                <TextBlock Opacity="0.68" Text="{Binding ParametersSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button
                    AutomationProperties.Name="{Binding [Operator_RemoveA11y], Source={StaticResource Localization}}"
                    Click="OnRemoveOperatorClick"
                    Content="{Binding [Operator_Remove], Source={StaticResource Localization}}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock FontWeight="SemiBold" Text="{Binding [Operator_TypedEdges], Source={StaticResource Localization}}" />
                <ListView
                    x:Name="EdgeList"
                    AutomationProperties.Name="{Binding [Operator_TypedEdgesA11y], Source={StaticResource Localization}}"
                    ItemsSource="{Binding RecipeEdges}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="4" Spacing="2">
                                <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                                <TextBlock Opacity="0.62" Text="{Binding EdgeId}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button
                    AutomationProperties.Name="{Binding [Operator_RemoveEdgeA11y], Source={StaticResource Localization}}"
                    Click="OnRemoveEdgeClick"
                    Content="{Binding [Operator_RemoveEdge], Source={StaticResource Localization}}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock FontWeight="SemiBold" Text="{Binding [Operator_ConnectPorts], Source={StaticResource Localization}}" />
            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SourceNodeText" Header="{Binding [Operator_SourceNodeId], Source={StaticResource Localization}}" />
                <TextBox x:Name="SourcePortText" Grid.Column="1" Header="{Binding [Operator_OutputPortId], Source={StaticResource Localization}}" />
                <TextBox x:Name="TargetNodeText" Grid.Column="2" Header="{Binding [Operator_TargetNodeId], Source={StaticResource Localization}}" />
                <TextBox x:Name="TargetPortText" Grid.Column="3" Header="{Binding [Operator_InputPortId], Source={StaticResource Localization}}" />
                <TextBox x:Name="TargetSlotText" Grid.Column="4" Header="{Binding [Operator_OptionalSlotId], Source={StaticResource Localization}}" />
                <Button
                    Grid.Column="5"
                    VerticalAlignment="Bottom"
                    AutomationProperties.Name="{Binding [Operator_ConnectA11y], Source={StaticResource Localization}}"
                    Click="OnAddEdgeClick"
                    Content="{Binding [Operator_Connect], Source={StaticResource Localization}}" />
            </Grid>
        </StackPanel>

        <TextBlock
            x:Name="GraphErrorText"
            Grid.Row="3"
            Foreground="IndianRed"
            TextWrapping="Wrap"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
