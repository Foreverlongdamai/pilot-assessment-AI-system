<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Editors.CptGridEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="12">
        <InfoBar
            IsClosable="False"
            IsOpen="True"
            Message="{Binding StatusMessage}"
            Severity="Informational"
            Title="{Binding [Cpt_BackendOwned], Source={StaticResource Localization}}" />
        <InfoBar
            x:Name="ErrorBar"
            IsClosable="True"
            IsOpen="False"
            Severity="Error"
            Title="{Binding [Cpt_OperationBlocked], Source={StaticResource Localization}}" />

        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock FontWeight="SemiBold" Text="{Binding ModeSummary}" TextWrapping="Wrap" />
                <TextBlock Opacity="0.72" Text="{Binding ValidationSummary}" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1" Click="OnToggleExpandedClick" Content="{Binding [Cpt_ExpandGrid], Source={StaticResource Localization}}" />
            <Button Grid.Column="2" Click="OnSaveRowsClick" Content="{Binding [Cpt_SaveRows], Source={StaticResource Localization}}" />
        </Grid>

        <Grid Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="170" />
            </Grid.ColumnDefinitions>
            <TextBlock FontWeight="SemiBold" Text="{Binding [Cpt_ParentAssignment], Source={StaticResource Localization}}" />
            <ItemsRepeater Grid.Column="1" ItemsSource="{Binding Columns}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="6" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Width="104" FontWeight="SemiBold" Text="{Binding StateId}" TextAlignment="Center" TextWrapping="Wrap" />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{Binding [Cpt_RowCheck], Source={StaticResource Localization}}" />
        </Grid>

        <ListView
            x:Name="CptRowsList"
            MaxHeight="520"
            ItemsSource="{Binding Rows}"
            SelectionMode="None">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="6,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="{Binding AssignmentLabel}" TextWrapping="Wrap" />
                        <ItemsRepeater Grid.Column="1" ItemsSource="{Binding Cells}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="6" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <TextBox
                                        Width="104"
                                        AutomationProperties.Name="{Binding StateId}"
                                        Text="{Binding ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="OnCellTextChanged" />
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Opacity="0.72" Text="{Binding RowStatus}" TextWrapping="Wrap" />
                        <Button Grid.Column="3" Click="OnNormalizeRowClick" Content="{Binding [Cpt_Normalize], Source={StaticResource Localization}}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Expander Header="{Binding [Cpt_PasteBlock], Source={StaticResource Localization}}">
            <StackPanel Padding="0,10,0,0" Spacing="8">
                <TextBlock Opacity="0.72" Text="{Binding [Cpt_PasteDescription], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PasteStartRowBox" Header="{Binding [Cpt_StartRow], Source={StaticResource Localization}}" Text="0" />
                    <TextBox x:Name="PasteStartColumnBox" Grid.Column="1" Header="{Binding [Cpt_StartColumn], Source={StaticResource Localization}}" Text="0" />
                    <Button Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Click="OnApplyPasteClick" Content="{Binding [Cpt_ApplyLocally], Source={StaticResource Localization}}" />
                </Grid>
                <TextBox x:Name="PasteTextBox" AcceptsReturn="True" Header="{Binding [Cpt_ProbabilityBlock], Source={StaticResource Localization}}" MinHeight="100" FontFamily="Consolas" />
            </StackPanel>
        </Expander>

        <Expander Header="{Binding [Cpt_BackendGenerator], Source={StaticResource Localization}}">
            <StackPanel Padding="0,10,0,0" Spacing="8">
                <TextBlock Opacity="0.72" Text="{Binding [Cpt_GeneratorDescription], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Header="{Binding [Cpt_Strategy], Source={StaticResource Localization}}" ItemsSource="{Binding MaterializationStrategies}" SelectedItem="{Binding MaterializationStrategy, Mode=TwoWay}" />
                    <TextBox Grid.Column="1" Header="{Binding [Cpt_RankedWeights], Source={StaticResource Localization}}" Text="{Binding RankedWeightsText, Mode=TwoWay}" />
                    <NumberBox Grid.Column="2" Header="{Binding [Cpt_WeakestLink], Source={StaticResource Localization}}" Value="{Binding WeakestLinkStrength, Mode=TwoWay}" />
                    <NumberBox Grid.Column="3" Header="{Binding [Cpt_Sigma], Source={StaticResource Localization}}" Value="{Binding Sigma, Mode=TwoWay}" />
                    <Button Grid.Column="4" VerticalAlignment="Bottom" Click="OnMaterializeClick" Content="{Binding [Cpt_Materialize], Source={StaticResource Localization}}" />
                </Grid>
            </StackPanel>
        </Expander>
    </StackPanel>
</UserControl>
