<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Editors.RawInputEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="12">
        <InfoBar
            IsClosable="False"
            IsOpen="True"
            Message="{Binding [Raw_ContractDescription], Source={StaticResource Localization}}"
            Severity="Informational"
            Title="{Binding [Raw_ContractTitle], Source={StaticResource Localization}}" />
        <TabView MinHeight="520">
            <TabViewItem Header="{Binding [Editor_General], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Header="{Binding [Editor_CanonicalName], Source={StaticResource Localization}}" Text="{Binding Name, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Column="1" Header="{Binding [Editor_CanonicalDescription], Source={StaticResource Localization}}" Text="{Binding Description, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Opacity="0.68" Text="{Binding [Editor_CanonicalEnglishHint], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                            <TextBox Grid.Row="2" Header="{Binding [Common_Group], Source={StaticResource Localization}}" Text="{Binding Group, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="2" Grid.Column="1" Header="{Binding [Editor_TagsSeparated], Source={StaticResource Localization}}" Text="{Binding TagsText, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <ComboBox Grid.Row="3" Header="{Binding [Raw_InputFamily], Source={StaticResource Localization}}" ItemsSource="{Binding Families}" SelectedItem="{Binding Family, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                            <ComboBox Grid.Row="3" Grid.Column="1" Header="{Binding [Raw_ResourceRole], Source={StaticResource Localization}}" ItemsSource="{Binding ResourceRoles}" SelectedItem="{Binding ResourceRole, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Raw_SourceSchema], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Header="{Binding [Raw_SourceId], Source={StaticResource Localization}}" Text="{Binding SourceId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <ComboBox Grid.Column="1" Header="{Binding [Raw_SourceKind], Source={StaticResource Localization}}" ItemsSource="{Binding SourceKinds}" SelectedItem="{Binding SourceKind, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                            <TextBox Grid.Row="1" Header="{Binding [Raw_SourceName], Source={StaticResource Localization}}" Text="{Binding SourceName, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="1" Grid.Column="1" Header="{Binding [Raw_SourceDescription], Source={StaticResource Localization}}" Text="{Binding SourceDescription, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Row="2" Header="{Binding [Raw_SchemaId], Source={StaticResource Localization}}" Text="{Binding SchemaId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="2" Grid.Column="1" Header="{Binding [Raw_AdapterId], Source={StaticResource Localization}}" Text="{Binding AdapterId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="3" Header="{Binding [Raw_ProfileId], Source={StaticResource Localization}}" Text="{Binding ProfileId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="3" Grid.Column="1" Header="{Binding [Raw_ClockBinding], Source={StaticResource Localization}}" Text="{Binding ClockBinding, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="4" Grid.ColumnSpan="2" AcceptsReturn="True" Header="{Binding [Raw_SourceDependencies], Source={StaticResource Localization}}" MinHeight="76" Text="{Binding SourceDependenciesText, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox AcceptsReturn="True" Header="{Binding [Raw_FieldsJson], Source={StaticResource Localization}}" MinHeight="130" Text="{Binding FieldsJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Column="1" AcceptsReturn="True" Header="{Binding [Raw_UnitsJson], Source={StaticResource Localization}}" MinHeight="130" Text="{Binding UnitsJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        </Grid>
                        <TextBox AcceptsReturn="True" Header="{Binding [Raw_MetadataJson], Source={StaticResource Localization}}" MinHeight="180" Text="{Binding MetadataJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Raw_TypeClock], Source={StaticResource Localization}}">
                <ScrollViewer Padding="4,12">
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ComboBox Header="{Binding [Dialog_RawModality], Source={StaticResource Localization}}" ItemsSource="{Binding Modalities}" SelectedItem="{Binding RawModality, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        <TextBox Grid.Column="1" Header="{Binding [Raw_ValueType], Source={StaticResource Localization}}" Text="{Binding ValueType, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                        <ComboBox Grid.Row="1" Header="{Binding [Raw_Cardinality], Source={StaticResource Localization}}" ItemsSource="{Binding Cardinalities}" SelectedItem="{Binding Cardinality, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        <ComboBox Grid.Row="1" Grid.Column="1" Header="{Binding [Raw_TemporalSemantics], Source={StaticResource Localization}}" ItemsSource="{Binding TemporalOptions}" SelectedItem="{Binding TemporalSemantics, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        <TextBox Grid.Row="2" Header="{Binding [Raw_Unit], Source={StaticResource Localization}}" Text="{Binding Unit, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                    </Grid>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="{Binding [Raw_SessionAvailability], Source={StaticResource Localization}}">
                <ListView Margin="4,12" ItemsSource="{Binding SessionAvailability}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                    <TextBlock Opacity="0.66" Text="{Binding Modality}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Readiness}" />
                                <TextBlock Grid.Column="2" Text="{Binding Detail}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabViewItem>

            <TabViewItem Header="{Binding [Editor_Help], Source={StaticResource Localization}}">
                <StackPanel Padding="4,12" Spacing="8">
                    <TextBlock Opacity="0.68" Text="{Binding [Editor_CanonicalEnglishHint], Source={StaticResource Localization}}" TextWrapping="Wrap" />
                    <TextBox AcceptsReturn="True" Header="{Binding [Editor_CanonicalHelp], Source={StaticResource Localization}}" MinHeight="220" Text="{Binding HelpText, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                </StackPanel>
            </TabViewItem>
        </TabView>
    </StackPanel>
</UserControl>
