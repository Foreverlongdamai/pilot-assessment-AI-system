<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Editors.RawInputEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="12">
        <InfoBar
            IsClosable="False"
            IsOpen="True"
            Message="This node declares how one managed Session Bundle resource is exposed to Evidence recipes. Ordinary fields autosave after 350 ms and reconcile with the canonical backend response."
            Severity="Informational"
            Title="Raw Input contract editor" />
        <TabView MinHeight="520">
            <TabViewItem Header="General">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Header="English name" Text="{Binding NameEn, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Column="1" Header="中文名称" Text="{Binding NameZh, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="1" Header="English description" Text="{Binding DescriptionEn, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Row="1" Grid.Column="1" Header="中文说明" Text="{Binding DescriptionZh, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Row="2" Header="Group" Text="{Binding Group, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="2" Grid.Column="1" Header="Tags (comma/newline separated)" Text="{Binding TagsText, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <ComboBox Grid.Row="3" Header="Input family" ItemsSource="{Binding Families}" SelectedItem="{Binding Family, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                            <ComboBox Grid.Row="3" Grid.Column="1" Header="Resource role" ItemsSource="{Binding ResourceRoles}" SelectedItem="{Binding ResourceRole, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Source &amp; schema">
                <ScrollViewer Padding="4,12">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Header="Source ID" Text="{Binding SourceId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <ComboBox Grid.Column="1" Header="Source kind" ItemsSource="{Binding SourceKinds}" SelectedItem="{Binding SourceKind, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                            <TextBox Grid.Row="1" Header="Source name" Text="{Binding SourceName, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="1" Grid.Column="1" Header="Source description" Text="{Binding SourceDescription, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Row="2" Header="Schema ID" Text="{Binding SchemaId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="2" Grid.Column="1" Header="Adapter ID" Text="{Binding AdapterId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="3" Header="Profile ID" Text="{Binding ProfileId, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="3" Grid.Column="1" Header="Clock binding" Text="{Binding ClockBinding, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                            <TextBox Grid.Row="4" Grid.ColumnSpan="2" AcceptsReturn="True" Header="Source dependencies (one per line)" MinHeight="76" Text="{Binding SourceDependenciesText, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox AcceptsReturn="True" Header="Fields JSON array" MinHeight="130" Text="{Binding FieldsJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                            <TextBox Grid.Column="1" AcceptsReturn="True" Header="Units JSON object" MinHeight="130" Text="{Binding UnitsJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                        </Grid>
                        <TextBox AcceptsReturn="True" Header="Complete metadata JSON (unknown fields are preserved)" MinHeight="180" Text="{Binding MetadataJson, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Type &amp; clock">
                <ScrollViewer Padding="4,12">
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ComboBox Header="Raw modality" ItemsSource="{Binding Modalities}" SelectedItem="{Binding RawModality, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        <TextBox Grid.Column="1" Header="Value type" Text="{Binding ValueType, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                        <ComboBox Grid.Row="1" Header="Cardinality" ItemsSource="{Binding Cardinalities}" SelectedItem="{Binding Cardinality, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        <ComboBox Grid.Row="1" Grid.Column="1" Header="Temporal semantics" ItemsSource="{Binding TemporalOptions}" SelectedItem="{Binding TemporalSemantics, Mode=TwoWay}" SelectionChanged="OnSelectionChanged" />
                        <TextBox Grid.Row="2" Header="Unit" Text="{Binding Unit, Mode=TwoWay}" TextChanged="OnFieldChanged" />
                    </Grid>
                </ScrollViewer>
            </TabViewItem>

            <TabViewItem Header="Session availability">
                <ListView Margin="4,12" ItemsSource="{Binding SessionAvailability}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                    <TextBlock Opacity="0.66" Text="{Binding Modality}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Readiness}" />
                                <TextBlock Grid.Column="2" Text="{Binding Detail}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabViewItem>

            <TabViewItem Header="Help">
                <Grid Padding="4,12" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox AcceptsReturn="True" Header="English help" MinHeight="220" Text="{Binding HelpTextEn, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                    <TextBox Grid.Column="1" AcceptsReturn="True" Header="中文帮助" MinHeight="220" Text="{Binding HelpTextZh, Mode=TwoWay}" TextChanged="OnFieldChanged" TextWrapping="Wrap" />
                </Grid>
            </TabViewItem>
        </TabView>
    </StackPanel>
</UserControl>
