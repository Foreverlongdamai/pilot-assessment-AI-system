<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Graph.GraphNodeButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button
        x:Name="NodeButton"
        Width="116"
        Height="116"
        Padding="0"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        Background="Transparent"
        BorderThickness="0"
        Click="OnNodeClick"
        CornerRadius="58"
        PointerCanceled="OnPointerCanceled"
        PointerMoved="OnPointerMoved"
        PointerPressed="OnPointerPressed"
        PointerReleased="OnPointerReleased">
        <Button.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Click="OnSelectClick" Text="Select node">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE73E;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Click="OnToggleSelectionClick" Text="Add/remove from selection">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE762;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Click="OnOpenDetailsClick" Text="Open node details">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8A7;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    x:Name="ActivateItem"
                    Click="OnActivateClick"
                    Text="Activate in this task" />
                <MenuFlyoutItem
                    x:Name="DeactivateItem"
                    Click="OnDeactivateClick"
                    Text="Deactivate from this task (Delete)" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Click="OnCopyClick" Text="Copy complete node" />
                <MenuFlyoutItem Click="OnPasteClick" Text="Paste into current task" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    Click="OnConnectParentClick"
                    Text="Connect selected parent to this node" />
                <MenuFlyoutItem
                    Click="OnRemoveParentClick"
                    Text="Remove selected parent from this node" />
            </MenuFlyout>
        </Button.ContextFlyout>
        <Grid>
            <Ellipse
                x:Name="NodeSurface"
                Margin="4"
                Stroke="White"
                StrokeThickness="1.5" />
            <Ellipse
                x:Name="SelectionRing"
                Margin="1"
                Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}"
                StrokeThickness="4"
                Visibility="Collapsed" />
            <StackPanel
                Margin="13,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="2">
                <FontIcon
                    x:Name="KindGlyph"
                    FontSize="16"
                    Foreground="White" />
                <TextBlock
                    x:Name="NameText"
                    MaxHeight="42"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="KindText"
                    HorizontalAlignment="Center"
                    FontSize="9"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Opacity="0.82"
                    TextAlignment="Center" />
                <TextBlock
                    x:Name="StatusText"
                    HorizontalAlignment="Center"
                    FontSize="9"
                    Foreground="White"
                    Opacity="0.72"
                    TextAlignment="Center" />
            </StackPanel>
            <Border
                x:Name="OutputBadge"
                Margin="0,0,9,8"
                Padding="5,2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="6"
                Visibility="Collapsed">
                <TextBlock FontSize="8" FontWeight="Bold" Foreground="White" Text="OUT" />
            </Border>
        </Grid>
    </Button>
</UserControl>
