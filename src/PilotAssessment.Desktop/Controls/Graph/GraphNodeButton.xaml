<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Graph.GraphNodeButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button
        x:Name="NodeButton"
        Width="116"
        Height="116"
        Padding="0"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        Background="Transparent"
        BorderThickness="0"
        Click="OnNodeClick"
        CornerRadius="58"
        DoubleTapped="OnNodeDoubleTapped"
        AutomationProperties.HelpText="{Binding [Graph_NodeHelp], Source={StaticResource Localization}}">
        <Button.ContextFlyout>
            <MenuFlyout>
                <MenuFlyoutItem Click="OnSelectClick" Text="{Binding [Graph_SelectNode], Source={StaticResource Localization}}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE73E;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem Click="OnToggleSelectionClick" Text="{Binding [Graph_ToggleSelection], Source={StaticResource Localization}}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE762;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Click="OnOpenDetailsClick" Text="{Binding [Graph_OpenNodeDetails], Source={StaticResource Localization}}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8A7;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    x:Name="ActivateItem"
                    Click="OnActivateClick"
                    Text="{Binding [Graph_ActivateTask], Source={StaticResource Localization}}" />
                <MenuFlyoutItem
                    x:Name="DeactivateItem"
                    Click="OnDeactivateClick"
                    Text="{Binding [Graph_DeactivateTask], Source={StaticResource Localization}}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Click="OnCopyClick" Text="{Binding [Graph_CopyNode], Source={StaticResource Localization}}" />
                <MenuFlyoutItem Click="OnPasteClick" Text="{Binding [Graph_PasteTask], Source={StaticResource Localization}}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    Click="OnConnectParentClick"
                    Text="{Binding [Graph_ConnectParent], Source={StaticResource Localization}}" />
                <MenuFlyoutItem
                    Click="OnRemoveParentClick"
                    Text="{Binding [Graph_RemoveParent], Source={StaticResource Localization}}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    x:Name="DeleteNodeItem"
                    Click="OnDeleteNodeClick"
                    Text="{Binding [Graph_DeleteNode], Source={StaticResource Localization}}">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE74D;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Button.ContextFlyout>
        <Grid>
            <Ellipse
                x:Name="NodeSurface"
                Margin="4"
                Stroke="{ThemeResource GraphNodeForegroundBrush}"
                StrokeThickness="1.5" />
            <Ellipse
                x:Name="SelectionRing"
                Margin="1"
                Stroke="{ThemeResource AccentTextFillColorPrimaryBrush}"
                StrokeThickness="4"
                Visibility="Collapsed" />
            <StackPanel
                Margin="13,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="2">
                <FontIcon
                    x:Name="KindGlyph"
                    FontSize="16"
                    Foreground="{ThemeResource GraphNodeForegroundBrush}" />
                <TextBlock
                    x:Name="NameText"
                    MaxHeight="42"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource GraphNodeForegroundBrush}"
                    TextAlignment="Center"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="KindText"
                    HorizontalAlignment="Center"
                    FontSize="9"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource GraphNodeForegroundBrush}"
                    Opacity="0.82"
                    TextAlignment="Center" />
                <TextBlock
                    x:Name="StatusText"
                    HorizontalAlignment="Center"
                    FontSize="9"
                    Foreground="{ThemeResource GraphNodeForegroundBrush}"
                    Opacity="0.72"
                    TextAlignment="Center" />
            </StackPanel>
            <Border
                x:Name="OutputBadge"
                Margin="0,0,9,8"
                Padding="5,2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="6"
                Visibility="Collapsed">
                <TextBlock
                    FontSize="8"
                    FontWeight="Bold"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                    Text="{Binding [Graph_OutputBadge], Source={StaticResource Localization}}" />
            </Border>
        </Grid>
    </Button>
</UserControl>
