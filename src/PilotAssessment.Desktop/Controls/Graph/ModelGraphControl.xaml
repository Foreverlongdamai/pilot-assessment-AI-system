<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Graph.ModelGraphControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:graph="using:PilotAssessment.Desktop.Controls.Graph"
    xmlns:state="using:PilotAssessment.Desktop.Core.State"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded">
    <Grid Background="{ThemeResource LayerFillColorAltBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer
            x:Name="GraphScrollViewer"
            Grid.Row="0"
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Enabled"
            MaxZoomFactor="2.5"
            MinZoomFactor="0.25"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled"
            ViewChanged="OnViewChanged"
            ZoomMode="Enabled">
            <Grid
                x:Name="GraphSurface"
                Width="{x:Bind ViewModel.ExtentWidth, Mode=OneWay}"
                Height="{x:Bind ViewModel.ExtentHeight, Mode=OneWay}"
                Background="Transparent"
                PointerCanceled="OnGraphPointerCanceled"
                PointerMoved="OnGraphPointerMoved"
                PointerPressed="OnGraphPointerPressed"
                PointerReleased="OnGraphPointerReleased">
                <Canvas
                    x:Name="EdgeLayer"
                    Width="{x:Bind ViewModel.ExtentWidth, Mode=OneWay}"
                    Height="{x:Bind ViewModel.ExtentHeight, Mode=OneWay}"
                    IsHitTestVisible="False" />
                <Canvas
                    x:Name="FamilyNodeLayer"
                    Width="{x:Bind ViewModel.ExtentWidth, Mode=OneWay}"
                    Height="{x:Bind ViewModel.ExtentHeight, Mode=OneWay}" />
                <ItemsRepeater
                    x:Name="NodeRepeater"
                    ItemsSource="{x:Bind ViewModel.Nodes}"
                    Layout="{x:Bind NodeLayout}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="state:GraphNodeProjection">
                            <graph:GraphNodeButton
                                Node="{Binding}"
                                NodeCommandRequested="OnNodeCommandRequested"
                                NodeDragCompleted="OnNodeDragCompleted"
                                NodeInvoked="OnNodeInvoked" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Grid>
        </ScrollViewer>

        <Border
            Margin="14"
            Padding="6"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button
                    AutomationProperties.Name="{Binding [Graph_ZoomOutA11y], Source={StaticResource Localization}}"
                    Click="OnZoomOutClick"
                    Content="&#xE71F;"
                    FontFamily="Segoe Fluent Icons" />
                <TextBlock
                    x:Name="ZoomText"
                    MinWidth="48"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="100%"
                    TextAlignment="Center" />
                <Button
                    AutomationProperties.Name="{Binding [Graph_ZoomInA11y], Source={StaticResource Localization}}"
                    Click="OnZoomInClick"
                    Content="&#xE8A3;"
                    FontFamily="Segoe Fluent Icons" />
                <Button Click="OnFitClick" Content="{Binding [Graph_Fit], Source={StaticResource Localization}}" />
            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            Margin="0"
            Padding="12,8"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <ScrollViewer
                HorizontalScrollBarVisibility="Auto"
                HorizontalScrollMode="Auto"
                VerticalScrollBarVisibility="Disabled"
                VerticalScrollMode="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="18">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Text="{Binding [Graph_EdgeLegend], Source={StaticResource Localization}}" />
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Rectangle
                            Width="28"
                            Height="2"
                            VerticalAlignment="Center"
                            Fill="{ThemeResource GraphProvenanceEdgeBrush}"
                            StrokeDashArray="2,2" />
                        <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding [Graph_ProvenanceEdge], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Rectangle
                            Width="28"
                            Height="2"
                            VerticalAlignment="Center"
                            Fill="{ThemeResource GraphExtractionEdgeBrush}"
                            StrokeDashArray="3,2" />
                        <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding [Graph_ExtractionEdge], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Rectangle
                            Width="28"
                            Height="2"
                            VerticalAlignment="Center"
                            Fill="{ThemeResource GraphProbabilisticEdgeBrush}" />
                        <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding [Graph_ProbabilisticEdge], Source={StaticResource Localization}}" />
                    </StackPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="10"
                        Opacity="0.68"
                        Text="{Binding [Graph_DimMeaning], Source={StaticResource Localization}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="10"
                        Opacity="0.68"
                        Text="{Binding [Graph_PanHint], Source={StaticResource Localization}}" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border
            Margin="14"
            Padding="7"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8">
            <StackPanel Spacing="4">
                <TextBlock FontSize="10" FontWeight="SemiBold" Text="{Binding [Graph_Minimap], Source={StaticResource Localization}}" />
                <Canvas
                    x:Name="MinimapCanvas"
                    Width="180"
                    Height="110"
                    Background="{ThemeResource LayerFillColorAltBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
