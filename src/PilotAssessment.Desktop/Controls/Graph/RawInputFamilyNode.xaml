<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PilotAssessment.Desktop.Controls.Graph.RawInputFamilyNode"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="148"
    Height="148"
    IsTabStop="True">
    <Grid>
        <Ellipse
            Fill="{ThemeResource GraphRawInputFamilyNodeBrush}"
            Stroke="{ThemeResource GraphRawInputFamilyBorderBrush}"
            StrokeThickness="3" />
        <StackPanel
            Margin="18"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                x:Name="SymbolText"
                HorizontalAlignment="Center"
                FontSize="28"
                FontWeight="Bold"
                Foreground="{ThemeResource GraphRawInputFamilyForegroundBrush}" />
            <TextBlock
                x:Name="NameText"
                MaxWidth="112"
                HorizontalAlignment="Center"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="{ThemeResource GraphRawInputFamilyForegroundBrush}"
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis"
                TextWrapping="Wrap" />
            <TextBlock
                x:Name="KindText"
                MaxWidth="116"
                HorizontalAlignment="Center"
                FontSize="9"
                Foreground="{ThemeResource GraphRawInputFamilyForegroundBrush}"
                Opacity="0.82"
                TextAlignment="Center"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
