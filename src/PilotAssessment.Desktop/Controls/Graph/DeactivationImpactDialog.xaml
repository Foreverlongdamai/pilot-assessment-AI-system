<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="PilotAssessment.Desktop.Controls.Graph.DeactivationImpactDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CloseButtonText="{Binding [Common_Cancel], Source={StaticResource Localization}}"
    DefaultButton="Close"
    PrimaryButtonText="{Binding [Common_Continue], Source={StaticResource Localization}}"
    Title="{Binding [Dialog_DeactivateTitle], Source={StaticResource Localization}}">
    <StackPanel Width="460" Spacing="10">
        <TextBlock
            x:Name="SummaryText"
            TextWrapping="Wrap" />
        <Border
            MaxHeight="260"
            Padding="10"
            Background="{ThemeResource LayerFillColorAltBrush}"
            CornerRadius="8">
            <ListView
                x:Name="ImpactedNodesList"
                IsItemClickEnabled="False"
                SelectionMode="None" />
        </Border>
        <TextBlock
            Opacity="0.64"
            Text="{Binding [Dialog_DeactivateSafety], Source={StaticResource Localization}}"
            TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>
