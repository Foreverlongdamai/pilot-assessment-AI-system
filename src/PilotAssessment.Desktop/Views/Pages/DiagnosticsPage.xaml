<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel MaxWidth="960" Padding="28" Spacing="18">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{Binding [Diagnostics_Title], Source={StaticResource Localization}}" />
            <TextBlock
                MaxWidth="760"
                Opacity="0.72"
                Text="{Binding [Diagnostics_Description], Source={StaticResource Localization}}"
                TextWrapping="Wrap" />
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasStartupError, Mode=OneWay}"
                Message="{x:Bind ViewModel.StartupError, Mode=OneWay}"
                Severity="Error"
                Title="{Binding [Diagnostics_StartupFailed], Source={StaticResource Localization}}" />
            <CommandBar DefaultLabelPosition="Right">
                <AppBarButton
                AutomationProperties.Name="{Binding [A11y_ReconnectBackend], Source={StaticResource Localization}}"
                    Command="{x:Bind ViewModel.ReconnectCommand}"
                Label="{Binding [Common_Reconnect], Source={StaticResource Localization}}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE72C;" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>
            <Grid ColumnSpacing="20" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="{Binding [Diagnostics_BackendState], Source={StaticResource Localization}}" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.BackendStatusText, Mode=OneWay}" />
                    <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="{Binding [Diagnostics_Runtime], Source={StaticResource Localization}}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="{x:Bind ViewModel.BackendDetails, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </Grid>
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_Stderr], Source={StaticResource Localization}}" />
            <TextBox
                AutomationProperties.Name="{Binding [Diagnostics_StderrA11y], Source={StaticResource Localization}}"
                FontFamily="Consolas"
                IsReadOnly="True"
                MinHeight="220"
                AcceptsReturn="True"
                Text="{x:Bind ViewModel.DiagnosticText, Mode=OneWay}"
                TextWrapping="NoWrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
