<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel MaxWidth="960" Padding="28" Spacing="18">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Diagnostics" />
            <TextBlock
                MaxWidth="760"
                Opacity="0.72"
                Text="The desktop communicates with one local Python sidecar over private stdin/stdout JSON-RPC. No network port is used."
                TextWrapping="Wrap" />
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasStartupError, Mode=OneWay}"
                Message="{x:Bind ViewModel.StartupError, Mode=OneWay}"
                Severity="Error"
                Title="Backend startup failed" />
            <CommandBar DefaultLabelPosition="Right">
                <AppBarButton
                    AutomationProperties.Name="Reconnect local backend"
                    Command="{x:Bind ViewModel.ReconnectCommand}"
                    Label="Reconnect">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE72C;" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>
            <Grid ColumnSpacing="20" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock FontWeight="SemiBold" Text="Backend state" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.BackendStatusText, Mode=OneWay}" />
                <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="Runtime" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="{x:Bind ViewModel.BackendDetails, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </Grid>
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="stderr diagnostics" />
            <TextBox
                AutomationProperties.Name="Backend stderr diagnostics"
                FontFamily="Consolas"
                IsReadOnly="True"
                MinHeight="220"
                AcceptsReturn="True"
                Text="{x:Bind ViewModel.DiagnosticText, Mode=OneWay}"
                TextWrapping="NoWrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
