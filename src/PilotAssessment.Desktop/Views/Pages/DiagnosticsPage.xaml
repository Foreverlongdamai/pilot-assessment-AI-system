<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PilotAssessment.Desktop.ViewModels"
    Loaded="OnPageLoaded">
    <ScrollViewer>
        <StackPanel MaxWidth="960" Padding="28" Spacing="18">
            <TextBlock AutomationProperties.HeadingLevel="Level1" Style="{StaticResource TitleTextBlockStyle}" Text="{Binding [Diagnostics_Title], Source={StaticResource Localization}}" />
            <TextBlock
                MaxWidth="760"
                Opacity="0.72"
                Text="{Binding [Diagnostics_Description], Source={StaticResource Localization}}"
                TextWrapping="Wrap" />
            <InfoBar
                AutomationProperties.LiveSetting="Assertive"
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.Shell.HasStartupError, Mode=OneWay}"
                Message="{x:Bind ViewModel.Shell.StartupError, Mode=OneWay}"
                Severity="Error"
                Title="{Binding [Diagnostics_StartupFailed], Source={StaticResource Localization}}" />
            <CommandBar DefaultLabelPosition="Right">
                <AppBarButton
                AutomationProperties.Name="{Binding [A11y_ReconnectBackend], Source={StaticResource Localization}}"
                    Command="{x:Bind ViewModel.Shell.ReconnectCommand}"
                Label="{Binding [Common_Reconnect], Source={StaticResource Localization}}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE72C;" />
                    </AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    Label="{Binding [Common_Refresh], Source={StaticResource Localization}}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE72C;" /></AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>
            <Grid ColumnSpacing="20" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="{Binding [Diagnostics_BackendState], Source={StaticResource Localization}}" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.Shell.BackendStatusText, Mode=OneWay}" />
                    <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="{Binding [Diagnostics_Runtime], Source={StaticResource Localization}}" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="{x:Bind ViewModel.Shell.BackendDetails, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </Grid>
            <InfoBar
                AutomationProperties.LiveSetting="Assertive"
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error"
                Title="{Binding [Diagnostics_RefreshFailed], Source={StaticResource Localization}}" />
            <InfoBar
                AutomationProperties.LiveSetting="Assertive"
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.SourceRestartRequired, Mode=OneWay}"
                Message="{x:Bind ViewModel.SourceRestartMessage, Mode=OneWay}"
                Severity="Warning"
                Title="{Binding [Diagnostics_SourceRestartRequired], Source={StaticResource Localization}}" />
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_SystemModel], Source={StaticResource Localization}}" />
                    <TextBox
                        AutomationProperties.Name="{Binding [Diagnostics_SystemModel], Source={StaticResource Localization}}"
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        MinHeight="150"
                        AcceptsReturn="True"
                        Text="{x:Bind ViewModel.SystemModelText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_ProjectCompatibility], Source={StaticResource Localization}}" />
                    <TextBox
                        AutomationProperties.Name="{Binding [Diagnostics_ProjectCompatibility], Source={StaticResource Localization}}"
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        MinHeight="150"
                        AcceptsReturn="True"
                        Text="{x:Bind ViewModel.ProjectCompatibilityText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_BackendIdentity], Source={StaticResource Localization}}" />
                    <TextBlock FontFamily="Consolas" Text="{x:Bind ViewModel.BackendIdentityText, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_RuntimeStatus], Source={StaticResource Localization}}" />
                    <TextBlock Text="{x:Bind ViewModel.RuntimeStatusText, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_ProjectRecovery], Source={StaticResource Localization}}" />
                    <TextBlock Text="{x:Bind ViewModel.RecoveryText, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_BackendSource], Source={StaticResource Localization}}" />
                    <TextBox
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        MinHeight="170"
                        AcceptsReturn="True"
                        Text="{x:Bind ViewModel.BackendSourceText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_SchemaIdentities], Source={StaticResource Localization}}" />
                    <TextBox
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        MinHeight="180"
                        AcceptsReturn="True"
                        Text="{x:Bind ViewModel.SchemaIdentitiesText, Mode=OneWay}"
                        TextWrapping="NoWrap" />
                </StackPanel>
            </Grid>
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Expander Header="{Binding [Diagnostics_Capabilities], Source={StaticResource Localization}}" IsExpanded="False">
                    <TextBox
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        MinHeight="220"
                        AcceptsReturn="True"
                        Text="{x:Bind ViewModel.CapabilitiesText, Mode=OneWay}"
                        TextWrapping="NoWrap" />
                </Expander>
                <Expander Grid.Column="1" Header="{Binding [Diagnostics_MethodCatalog], Source={StaticResource Localization}}" IsExpanded="False">
                    <TextBox
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        MinHeight="220"
                        AcceptsReturn="True"
                        Text="{x:Bind ViewModel.MethodsText, Mode=OneWay}"
                        TextWrapping="NoWrap" />
                </Expander>
            </Grid>
            <Expander Header="{Binding [Diagnostics_AuditEvents], Source={StaticResource Localization}}" IsExpanded="False">
                <ListView MaxHeight="320" ItemsSource="{x:Bind ViewModel.AuditEvents}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:AuditEventItemViewModel">
                            <Grid Padding="5" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind OccurredAt}" />
                                <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{x:Bind EventType}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Subject}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="3" Text="{x:Bind Actor}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{Binding [Diagnostics_Stderr], Source={StaticResource Localization}}" />
            <TextBox
                AutomationProperties.Name="{Binding [Diagnostics_StderrA11y], Source={StaticResource Localization}}"
                FontFamily="Consolas"
                IsReadOnly="True"
                MinHeight="220"
                AcceptsReturn="True"
                Text="{x:Bind ViewModel.Shell.DiagnosticText, Mode=OneWay}"
                TextWrapping="NoWrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
