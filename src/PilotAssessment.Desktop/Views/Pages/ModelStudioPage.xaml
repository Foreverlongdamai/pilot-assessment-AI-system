<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.ModelStudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PilotAssessment.Desktop.Controls"
    xmlns:graph="using:PilotAssessment.Desktop.Controls.Graph"
    Loaded="OnPageLoaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="318" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <controls:TaskSchemeSidebar />
        <Rectangle Grid.Column="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Padding="18,14,18,10" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Model Studio" />
                    <TextBlock
                        Opacity="0.68"
                        Text="Global complete nodes • current task activation"
                        TextWrapping="Wrap" />
                </StackPanel>
                <ScrollViewer
                    Grid.Column="1"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox
                            Width="210"
                            AutomationProperties.Name="Search model nodes"
                            PlaceholderText="Search nodes"
                            TextChanged="OnSearchTextChanged" />
                        <ComboBox
                            Width="150"
                            AutomationProperties.Name="Graph visibility mode"
                            ItemsSource="{x:Bind ViewModel.ViewModes}"
                            SelectedItem="{x:Bind ViewModel.SelectedViewMode, Mode=TwoWay}" />
                        <ComboBox
                            Width="135"
                            AutomationProperties.Name="Node kind filter"
                            ItemsSource="{x:Bind ViewModel.KindOptions}"
                            SelectedItem="{x:Bind ViewModel.SelectedKind, Mode=TwoWay}" />
                        <ComboBox
                            Width="155"
                            AutomationProperties.Name="Activation filter"
                            ItemsSource="{x:Bind ViewModel.ActivationOptions}"
                            SelectedItem="{x:Bind ViewModel.SelectedActivation, Mode=TwoWay}" />
                        <ComboBox
                            Width="135"
                            AutomationProperties.Name="Node group filter"
                            ItemsSource="{x:Bind ViewModel.AvailableGroups}"
                            SelectedItem="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}" />
                        <ComboBox
                            Width="125"
                            AutomationProperties.Name="Node tag filter"
                            ItemsSource="{x:Bind ViewModel.AvailableTags}"
                            SelectedItem="{x:Bind ViewModel.SelectedTag, Mode=TwoWay}" />
                    </StackPanel>
                </ScrollViewer>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <ToggleButton
                        AutomationProperties.Name="Toggle multi-select"
                        Content="Multi-select"
                        IsChecked="{x:Bind ViewModel.IsMultiSelect, Mode=TwoWay}" />
                    <Button Click="OnClearSelectionClick" Content="Clear" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Padding="18,0,18,10" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="3">
                    <InfoBar
                        IsClosable="False"
                        IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                        Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        Severity="Error"
                        Title="Graph load failed" />
                    <TextBlock
                        FontSize="12"
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SelectedNodeSummary, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <ProgressRing
                    Grid.Column="1"
                    Width="28"
                    Height="28"
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            </Grid>

            <Border
                Grid.Row="2"
                Margin="18,0,18,18"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <graph:ModelGraphControl />
            </Border>
        </Grid>
    </Grid>
</Page>
