<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.ModelStudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PilotAssessment.Desktop.Controls"
    xmlns:graph="using:PilotAssessment.Desktop.Controls.Graph"
    Loaded="OnPageLoaded">
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="C" Modifiers="Control" Invoked="OnCopyAccelerator" />
        <KeyboardAccelerator Key="V" Modifiers="Control" Invoked="OnPasteAccelerator" />
        <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="OnUndoAccelerator" />
        <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="OnRedoAccelerator" />
        <KeyboardAccelerator Key="Delete" Invoked="OnDeleteAccelerator" />
    </Page.KeyboardAccelerators>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="318" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <controls:TaskSchemeSidebar />
        <Rectangle Grid.Column="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Padding="18,14,18,10" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock AutomationProperties.HeadingLevel="Level1" Style="{ThemeResource TitleTextBlockStyle}" Text="{Binding [Model_Title], Source={StaticResource Localization}}" />
                    <TextBlock
                        Opacity="0.68"
                        Text="{Binding [Model_Subtitle], Source={StaticResource Localization}}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <ScrollViewer
                    Grid.Column="1"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox
                            Width="210"
                            AutomationProperties.Name="{Binding [Model_SearchA11y], Source={StaticResource Localization}}"
                            PlaceholderText="{Binding [Model_SearchPlaceholder], Source={StaticResource Localization}}"
                            TextChanged="OnSearchTextChanged" />
                        <ComboBox
                            Width="150"
                            AutomationProperties.Name="{Binding [Model_ViewModeA11y], Source={StaticResource Localization}}"
                            ItemsSource="{x:Bind ViewModel.ViewModes}"
                            SelectedItem="{x:Bind ViewModel.SelectedViewMode, Mode=TwoWay}" />
                        <ComboBox
                            Width="160"
                            AutomationProperties.Name="{Binding [Model_LayerFilterA11y], Source={StaticResource Localization}}"
                            ItemsSource="{x:Bind ViewModel.LayerOptions}"
                            SelectedItem="{x:Bind ViewModel.SelectedLayer, Mode=TwoWay}" />
                        <ComboBox
                            Width="155"
                            AutomationProperties.Name="{Binding [Model_ActivationFilterA11y], Source={StaticResource Localization}}"
                            ItemsSource="{x:Bind ViewModel.ActivationOptions}"
                            SelectedItem="{x:Bind ViewModel.SelectedActivation, Mode=TwoWay}" />
                        <ComboBox
                            Width="135"
                            AutomationProperties.Name="{Binding [Model_GroupFilterA11y], Source={StaticResource Localization}}"
                            ItemsSource="{x:Bind ViewModel.AvailableGroups}"
                            SelectedItem="{x:Bind ViewModel.SelectedGroup, Mode=TwoWay}" />
                    </StackPanel>
                </ScrollViewer>
                <CommandBar
                    Grid.Column="2"
                    Background="Transparent"
                    DefaultLabelPosition="Collapsed"
                    IsDynamicOverflowEnabled="True">
                    <AppBarButton Icon="Add" Label="{Binding [Model_NewNode], Source={StaticResource Localization}}">
                        <AppBarButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Click="OnCreateRawInputClick" Text="{Binding [Model_NewRawInput], Source={StaticResource Localization}}" />
                                <MenuFlyoutItem Click="OnCreateEvidenceClick" Text="{Binding [Model_NewEvidence], Source={StaticResource Localization}}" />
                                <MenuFlyoutItem Click="OnCreateBnClick" Text="{Binding [Model_NewBn], Source={StaticResource Localization}}" />
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                    <AppBarButton
                        AutomationProperties.Name="{Binding [Model_OpenDetailsA11y], Source={StaticResource Localization}}"
                        Click="OnOpenSelectionClick"
                        Icon="OpenFile"
                        Label="{Binding [Model_OpenDetails], Source={StaticResource Localization}}" />
                    <AppBarButton Click="OnActivateSelectionClick" Icon="Accept" Label="{Binding [Model_Activate], Source={StaticResource Localization}}" />
                    <AppBarButton Click="OnDeactivateSelectionClick" Icon="Remove" Label="{Binding [Model_Deactivate], Source={StaticResource Localization}}" />
                    <AppBarButton Click="OnDeleteSelectionClick" Icon="Delete" Label="{Binding [Model_DeleteNode], Source={StaticResource Localization}}" />
                    <AppBarButton Click="OnCopySelectionClick" Icon="Copy" Label="{Binding [Common_Copy], Source={StaticResource Localization}}" />
                    <AppBarButton Click="OnPasteClick" Icon="Paste" Label="{Binding [Model_Paste], Source={StaticResource Localization}}" />
                    <AppBarToggleButton
                        AutomationProperties.Name="{Binding [Model_MultiSelectA11y], Source={StaticResource Localization}}"
                        Icon="SelectAll"
                        IsChecked="{x:Bind ViewModel.IsMultiSelect, Mode=TwoWay}"
                        Label="{Binding [Model_MultiSelect], Source={StaticResource Localization}}" />
                    <AppBarButton Click="OnClearSelectionClick" Icon="Clear" Label="{Binding [Model_ClearSelection], Source={StaticResource Localization}}" />
                </CommandBar>
            </Grid>

            <Grid Grid.Row="1" Padding="18,0,18,10" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="3">
                    <InfoBar
                        IsClosable="False"
                        IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                        Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                        Severity="Error"
                        Title="{Binding [Model_GraphLoadFailed], Source={StaticResource Localization}}" />
                    <TextBlock
                        AutomationProperties.LiveSetting="Polite"
                        FontSize="12"
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SelectedNodeSummary, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
                <ProgressRing
                    Grid.Column="1"
                    Width="28"
                    Height="28"
                    IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            </Grid>

            <Border
                Grid.Row="2"
                Margin="18,0,18,18"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <graph:ModelGraphControl NodeCommandRequested="OnGraphNodeCommandRequested" />
            </Border>
        </Grid>
    </Grid>
</Page>
