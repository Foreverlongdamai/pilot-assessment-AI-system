<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.ResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:state="using:PilotAssessment.Desktop.Core.State"
    xmlns:vm="using:PilotAssessment.Desktop.ViewModels"
    Loaded="OnPageLoaded">
    <ScrollViewer>
        <StackPanel Padding="28,24,28,48" Spacing="18">
            <StackPanel Spacing="6">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="{Binding [Results_Title], Source={StaticResource Localization}}" />
                <TextBlock
                    MaxWidth="980"
                    Opacity="0.72"
                    Text="{Binding [Results_Description], Source={StaticResource Localization}}"
                    TextWrapping="Wrap" />
            </StackPanel>
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error"
                Title="{Binding [Results_OperationFailed], Source={StaticResource Localization}}" />
            <InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="Informational"
                Title="{Binding [Common_Status], Source={StaticResource Localization}}" />
            <CommandBar DefaultLabelPosition="Right">
                <AppBarButton Command="{x:Bind ViewModel.RefreshCommand}" Label="{Binding [Common_Refresh], Source={StaticResource Localization}}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE72C;" /></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton Command="{x:Bind ViewModel.LoadSelectedCommand}" Label="{Binding [Results_Load], Source={StaticResource Localization}}">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE8B7;" /></AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Results_CompletedRuns], Source={StaticResource Localization}}" />
                        <ListView
                            MaxHeight="300"
                            ItemsSource="{x:Bind ViewModel.Runs}"
                            SelectedItem="{x:Bind ViewModel.SelectedRun, Mode=TwoWay}"
                            SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ResultRunItemViewModel">
                                    <StackPanel Padding="4" Spacing="3">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Opacity="0.65" Text="{x:Bind DetailText}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Results_Summary], Source={StaticResource Localization}}" />
                        <TextBlock FontFamily="Consolas" Text="{x:Bind ViewModel.ResultSummaryText, Mode=OneWay}" TextWrapping="Wrap" />
                        <InfoBar
                            IsClosable="False"
                            IsOpen="True"
                            Message="{x:Bind ViewModel.ScientificStatusText, Mode=OneWay}"
                            Severity="Warning"
                            Title="{Binding [Results_ScientificStatus], Source={StaticResource Localization}}" />
                        <TextBlock Text="{x:Bind ViewModel.CoverageText, Mode=OneWay}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <TabView>
                <TabViewItem Header="{Binding [Results_EvidenceTab], Source={StaticResource Localization}}">
                    <StackPanel Padding="4,12" Spacing="14">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Results_EvidenceDau], Source={StaticResource Localization}}" />
                        <ListView MaxHeight="360" ItemsSource="{x:Bind ViewModel.EvidenceRows}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="state:EvidenceResultProjection">
                                    <Grid Padding="5" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="240" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                            <TextBlock Opacity="0.62" Text="{x:Bind NodeId}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind CalculationStatus}" />
                                        <TextBlock Grid.Column="2" FontFamily="Consolas" Text="{x:Bind PrimaryValue}" />
                                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="{x:Bind DauState}" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind Score}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Results_Observations], Source={StaticResource Localization}}" />
                        <ListView MaxHeight="300" ItemsSource="{x:Bind ViewModel.ObservationRows}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="state:ObservationProjection">
                                    <Grid Padding="5" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="260" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Kind}" />
                                        <TextBlock Grid.Column="2" FontFamily="Consolas" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </TabViewItem>

                <TabViewItem Header="{Binding [Results_PosteriorTab], Source={StaticResource Localization}}">
                    <ListView Margin="4,12" MaxHeight="560" ItemsSource="{x:Bind ViewModel.PosteriorRows}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="state:PosteriorProjection">
                                <Grid Padding="6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                        <TextBlock Opacity="0.62" Text="{x:Bind NodeId}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind TopState}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind L1Change}" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind Distribution}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>

                <TabViewItem Header="{Binding [Results_InfluenceTab], Source={StaticResource Localization}}">
                    <StackPanel Padding="4,12" Spacing="12">
                        <InfoBar
                            IsClosable="False"
                            IsOpen="True"
                            Message="{x:Bind ViewModel.InfluenceExplanationText, Mode=OneWay}"
                            Severity="Informational"
                            Title="{Binding [Results_InfluenceNotCanonical], Source={StaticResource Localization}}" />
                        <ListView MaxHeight="520" ItemsSource="{x:Bind ViewModel.InfluenceRows}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="state:InfluenceProjection">
                                    <Grid Padding="6" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind ObservedNode}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="→" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind QueriedNode}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="3" FontFamily="Consolas" Text="{x:Bind L1Delta}" />
                                        <TextBlock Grid.Column="4" Opacity="0.68" Text="{x:Bind CanonicalPath}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </TabViewItem>

                <TabViewItem Header="{Binding [Results_ArtifactsTab], Source={StaticResource Localization}}">
                    <ListView Margin="4,12" MaxHeight="560" ItemsSource="{x:Bind ViewModel.Artifacts}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResultArtifactItemViewModel">
                                <Grid Padding="6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Role}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind SchemaId}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind SizeText}" />
                                    <TextBlock Grid.Column="3" FontFamily="Consolas" Text="{x:Bind PathText}" TextTrimming="CharacterEllipsis" />
                                    <Button
                                        Grid.Column="4"
                                        Click="OnOpenArtifactClick"
                                        Content="{Binding [Results_ShowInFolder], Source={StaticResource Localization}}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>

                <TabViewItem Header="{Binding [Results_ProvenanceTab], Source={StaticResource Localization}}">
                    <ListView Margin="4,12" MaxHeight="560" ItemsSource="{x:Bind ViewModel.ProvenanceRows}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProvenanceItemViewModel">
                                <Grid Padding="6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                    <TextBlock Grid.Column="1" FontFamily="Consolas" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
            </TabView>
        </StackPanel>
    </ScrollViewer>
</Page>
