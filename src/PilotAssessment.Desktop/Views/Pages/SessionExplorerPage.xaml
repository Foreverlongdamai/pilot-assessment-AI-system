<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.SessionExplorerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:contracts="using:PilotAssessment.Desktop.Core.Contracts"
    xmlns:vm="using:PilotAssessment.Desktop.Core.ViewModels"
    Loaded="OnPageLoaded"
    Unloaded="OnPageUnloaded"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Padding="28,24,28,48" Spacing="18">
            <StackPanel Spacing="6">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="{Binding [Session_Title], Source={StaticResource Localization}}" />
                <TextBlock
                    MaxWidth="920"
                    Opacity="0.72"
                    Text="{Binding [Session_Description], Source={StaticResource Localization}}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error"
                Title="{Binding [Session_OperationFailed], Source={StaticResource Localization}}" />
            <InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="Informational"
                Title="{Binding [Session_Status], Source={StaticResource Localization}}" />

            <Border
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Session_Workflow], Source={StaticResource Localization}}" />
                    <TextBox
                        Header="{Binding [Session_ExternalFolder], Source={StaticResource Localization}}"
                        IsReadOnly="True"
                        PlaceholderText="{Binding [Session_ChooseBundlePlaceholder], Source={StaticResource Localization}}"
                        Text="{x:Bind ViewModel.SourceBundlePath, Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button
                            Command="{x:Bind ViewModel.ChooseSessionBundleCommand}"
                            Content="{Binding [Session_ChooseBundle], Source={StaticResource Localization}}" />
                        <Button Command="{x:Bind ViewModel.InspectSessionCommand}" Content="{Binding [Session_Inspect], Source={StaticResource Localization}}" />
                        <Button
                            Command="{x:Bind ViewModel.ImportSessionCommand}"
                            Content="{Binding [Session_ImportManaged], Source={StaticResource Localization}}"
                            Style="{StaticResource AccentButtonStyle}" />
                        <Button Command="{x:Bind ViewModel.RefreshSessionsCommand}" Content="{Binding [Common_Refresh], Source={StaticResource Localization}}" />
                        <ProgressRing
                            Width="26"
                            Height="26"
                            IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                    </StackPanel>
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="3">
                            <TextBlock Opacity="0.65" Text="{Binding [Session_SourceKind], Source={StaticResource Localization}}" />
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SourceKindText, Mode=OneWay}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Opacity="0.65" Text="{Binding [Session_AdapterProfile], Source={StaticResource Localization}}" />
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SourceProfileText, Mode=OneWay}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.SourceMappingText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.InspectionSummary, Mode=OneWay}" />
                    <TextBlock
                        Opacity="0.72"
                        Text="{x:Bind ViewModel.InspectionIssues, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Session_ManagedSessions], Source={StaticResource Localization}}" />
                        <ListView
                            x:Name="SessionList"
                            MaxHeight="420"
                            ItemsSource="{x:Bind ViewModel.Sessions}"
                            SelectionChanged="OnSessionSelectionChanged"
                            SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="contracts:SessionCollectionItem">
                                    <StackPanel Padding="4">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding [Session_ManagedSessionItem], Source={StaticResource Localization}}" />
                                        <TextBlock Opacity="0.65" Text="{x:Bind Session.CreatedAt}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Session_SelectedRevision], Source={StaticResource Localization}}" />
                        <ComboBox
                            x:Name="RevisionSelector"
                            Header="{Binding [Common_Revision], Source={StaticResource Localization}}"
                            ItemsSource="{x:Bind ViewModel.Revisions}"
                            SelectionChanged="OnRevisionSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="contracts:SessionRevision">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding [Common_Revision], Source={StaticResource Localization}}" />
                                        <TextBlock Text="{x:Bind ImportedAt}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock FontWeight="SemiBold" Text="{Binding [Session_ManagedPath], Source={StaticResource Localization}}" />
                        <TextBlock Text="{x:Bind ViewModel.ManagedBundlePathText, Mode=OneWay}" TextWrapping="Wrap" />
                        <TextBlock FontWeight="SemiBold" Text="{Binding [Session_IngestionArtifact], Source={StaticResource Localization}}" />
                        <TextBlock Text="{x:Bind ViewModel.ReadinessArtifactText, Mode=OneWay}" TextWrapping="Wrap" />
                        <TextBlock FontWeight="SemiBold" Text="{Binding [Session_SyncArtifact], Source={StaticResource Localization}}" />
                        <TextBlock Text="{x:Bind ViewModel.SynchronizationArtifactText, Mode=OneWay}" TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,4,0,0"
                            Opacity="0.68"
                            Text="{Binding [Session_PathBoundary], Source={StaticResource Localization}}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="10">
                <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Session_InputFamilies], Source={StaticResource Localization}}" />
                <TextBlock
                    Opacity="0.68"
                    Text="{Binding [Session_InputFamiliesDescription], Source={StaticResource Localization}}"
                    TextWrapping="Wrap" />
                <GridView
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind ViewModel.Modalities}"
                    SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ModalityStatusItem">
                            <Border
                                Width="245"
                                MinHeight="142"
                                Padding="14"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8">
                                <StackPanel Spacing="5">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                    <TextBlock Opacity="0.65" Text="{x:Bind Family}" />
                                    <TextBlock Text="{x:Bind Modality}" />
                                    <TextBlock Text="{x:Bind DeclaredStatus}" />
                                    <TextBlock Text="{x:Bind Readiness}" />
                                    <TextBlock Opacity="0.68" Text="{x:Bind Detail}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
