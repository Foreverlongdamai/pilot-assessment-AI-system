<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.ProjectLauncherPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PilotAssessment.Desktop.Core.ViewModels"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel
            MaxWidth="1120"
            Padding="32,28,32,48"
            HorizontalAlignment="Stretch"
            Spacing="18">
            <StackPanel Spacing="6">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Projects" />
                <TextBlock
                    MaxWidth="780"
                    Opacity="0.72"
                    Text="A managed project contains the editable model library, task schemes, imported Session Bundles, runs and results. It can be moved as one folder."
                    TextWrapping="Wrap" />
            </StackPanel>

            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error"
                Title="Project operation failed" />
            <InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="Informational"
                Title="Project status" />

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="10">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Current project" />
                    <TextBlock Text="{x:Bind ViewModel.CurrentProjectText, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock
                        Opacity="0.65"
                        Text="{x:Bind ViewModel.CurrentProjectRootText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    <Button
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.CloseProjectCommand}"
                        Content="Close project" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Create managed project" />
                        <TextBox
                            Header="Project name"
                            Text="{x:Bind ViewModel.ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Header="Stable project ID"
                            Text="{x:Bind ViewModel.ProjectId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                            Header="Project folder"
                            IsReadOnly="True"
                            PlaceholderText="Choose an empty folder or a new folder path"
                            Text="{x:Bind ViewModel.CreateRootPath, Mode=OneWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button
                                Command="{x:Bind ViewModel.ChooseCreateFolderCommand}"
                                Content="Choose folder" />
                            <Button
                                Command="{x:Bind ViewModel.CreateProjectCommand}"
                                Content="Create and open"
                                Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Open managed project" />
                        <TextBlock
                            Text="Choose a folder that contains project.json and project.sqlite3. Opening does not copy or relocate it."
                            TextWrapping="Wrap" />
                        <Button
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.OpenProjectCommand}"
                            Content="Choose project folder"
                            Style="{StaticResource AccentButtonStyle}" />
                        <ProgressRing
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Left"
                            IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Recent projects" />
                    <TextBlock
                        Opacity="0.68"
                        Text="These are local path shortcuts only. No project or Session data is duplicated here."
                        TextWrapping="Wrap" />
                    <ListView
                        MaxHeight="300"
                        ItemsSource="{x:Bind ViewModel.RecentProjects}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:RecentProjectEntry">
                                <Grid Padding="4" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                        <TextBlock Opacity="0.65" Text="{x:Bind ProjectId}" />
                                        <TextBlock Opacity="0.65" Text="{x:Bind RootPath}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="OnOpenRecentClick"
                                        Content="Open" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
