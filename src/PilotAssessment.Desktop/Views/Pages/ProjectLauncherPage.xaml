<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PilotAssessment.Desktop.Views.Pages.ProjectLauncherPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PilotAssessment.Desktop.Core.ViewModels"
    mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel
            MaxWidth="1120"
            Padding="32,28,32,48"
            HorizontalAlignment="Stretch"
            Spacing="18">
            <StackPanel Spacing="6">
            <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="{Binding [Project_Title], Source={StaticResource Localization}}" />
                <TextBlock
                    MaxWidth="780"
                    Opacity="0.72"
                Text="{Binding [Project_Description], Source={StaticResource Localization}}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Severity="Error"
                Title="{Binding [Project_OperationFailed], Source={StaticResource Localization}}" />
            <InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Severity="Informational"
                Title="{Binding [Project_Status], Source={StaticResource Localization}}" />

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="10">
                <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Project_Current], Source={StaticResource Localization}}" />
                    <TextBlock Text="{x:Bind ViewModel.CurrentProjectText, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock
                        Opacity="0.65"
                        Text="{x:Bind ViewModel.CurrentProjectRootText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    <Button
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.CloseProjectCommand}"
                        Content="{Binding [Project_Close], Source={StaticResource Localization}}" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10">
                    <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Project_Create], Source={StaticResource Localization}}" />
                        <TextBox
                        Header="{Binding [Project_Name], Source={StaticResource Localization}}"
                            Text="{x:Bind ViewModel.ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox
                        Header="{Binding [Project_Folder], Source={StaticResource Localization}}"
                            IsReadOnly="True"
                        PlaceholderText="{Binding [Project_FolderPlaceholder], Source={StaticResource Localization}}"
                            Text="{x:Bind ViewModel.CreateRootPath, Mode=OneWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button
                                Command="{x:Bind ViewModel.ChooseCreateFolderCommand}"
                        Content="{Binding [Project_ChooseFolder], Source={StaticResource Localization}}" />
                            <Button
                                Command="{x:Bind ViewModel.CreateProjectCommand}"
                        Content="{Binding [Project_CreateAndOpen], Source={StaticResource Localization}}"
                                Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="10">
                    <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Project_OpenManaged], Source={StaticResource Localization}}" />
                        <TextBlock
                        Text="{Binding [Project_OpenDescription], Source={StaticResource Localization}}"
                            TextWrapping="Wrap" />
                        <Button
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.OpenProjectCommand}"
                        Content="{Binding [Project_ChooseProjectFolder], Source={StaticResource Localization}}"
                            Style="{StaticResource AccentButtonStyle}" />
                        <ProgressRing
                            Width="28"
                            Height="28"
                            HorizontalAlignment="Left"
                            IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="{Binding [Project_Recent], Source={StaticResource Localization}}" />
                    <TextBlock
                        Opacity="0.68"
                        Text="{Binding [Project_RecentDescription], Source={StaticResource Localization}}"
                        TextWrapping="Wrap" />
                    <ListView
                        MaxHeight="300"
                        ItemsSource="{x:Bind ViewModel.RecentProjects}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:RecentProjectEntry">
                                <Grid Padding="4" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind Name}" />
                                        <TextBlock Opacity="0.65" Text="{x:Bind RootPath}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="OnOpenRecentClick"
                                    Content="{Binding [Common_Open], Source={StaticResource Localization}}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
