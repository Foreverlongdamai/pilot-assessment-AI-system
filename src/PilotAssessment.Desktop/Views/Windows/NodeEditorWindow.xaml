<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PilotAssessment.Desktop.Views.Windows.NodeEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Node Editor">
    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="24,20,24,16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock
                    x:Name="NodeNameText"
                    AutomationProperties.HeadingLevel="Level1"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Node" />
                <TextBlock
                    x:Name="NodeIdentityText"
                    Opacity="0.68"
                    TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="3">
                <TextBlock
                    x:Name="NodeKindText"
                    HorizontalAlignment="Right"
                    FontWeight="SemiBold" />
                <TextBlock
                    x:Name="SaveStateText"
                    HorizontalAlignment="Right"
                    Opacity="0.72" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="24,8,24,28" Spacing="18">
                <InfoBar
                    x:Name="WindowModeInfoBar"
                    IsClosable="False"
                    IsOpen="True"
                    Message="This is an independent, non-modal editor window. The main graph remains interactive."
                    Severity="Informational"
                    Title="Independent node editor" />

                <Grid
                    x:Name="CanonicalConflictPanel"
                    Padding="16"
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    ColumnSpacing="12"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Canonical node changed" />
                        <TextBlock
                            Text="The backend returned a newer revision while this window has unsaved text. Reload it or keep editing for a later conflict-aware save."
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        AutomationProperties.Name="Reload canonical node"
                        Click="OnReloadCanonicalClick"
                        Content="Reload" />
                    <Button
                        Grid.Column="2"
                        AutomationProperties.Name="Keep editing local node values"
                        Click="OnKeepEditingClick"
                        Content="Keep editing" />
                </Grid>

                <StackPanel Spacing="8">
                    <TextBlock
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="Context / 上下文" />
                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Opacity="0.66" Text="Task scheme" />
                        <TextBlock x:Name="TaskSchemeText" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Opacity="0.66" Text="Shared usage" />
                        <TextBlock x:Name="SharedUsageText" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="2" Opacity="0.66" Text="Window key" />
                        <TextBlock x:Name="WindowKeyText" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <StackPanel Spacing="8">
                    <TextBlock
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="Canonical definition / 后端权威定义" />
                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Opacity="0.66" Text="Technical status" />
                        <TextBlock x:Name="TechnicalStatusText" Grid.Column="1" />
                        <TextBlock Grid.Row="1" Opacity="0.66" Text="Semantic revision" />
                        <TextBlock x:Name="SemanticRevisionText" Grid.Row="1" Grid.Column="1" />
                        <TextBlock Grid.Row="2" Opacity="0.66" Text="Layout revision" />
                        <TextBlock x:Name="LayoutRevisionText" Grid.Row="2" Grid.Column="1" />
                        <TextBlock Grid.Row="3" Opacity="0.66" Text="Group" />
                        <TextBlock x:Name="GroupText" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="4" Opacity="0.66" Text="Tags" />
                        <TextBlock x:Name="TagsText" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>

                <ContentControl x:Name="EditorHost">
                    <InfoBar
                        IsClosable="False"
                        IsOpen="True"
                        Message="This node type does not yet have its complete editor surface."
                        Severity="Informational"
                        Title="Editor surface" />
                </ContentControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
