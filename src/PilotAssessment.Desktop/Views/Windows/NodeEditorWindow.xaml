<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PilotAssessment.Desktop.Views.Windows.NodeEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PilotAssessment.Desktop.Controls"
    Title="{Binding [Node_DefaultTitle], Source={StaticResource Localization}}">
    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="24,20,24,16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock
                    x:Name="NodeNameText"
                    AutomationProperties.HeadingLevel="Level1"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="{Binding [Node_Header], Source={StaticResource Localization}}" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="3">
                <TextBlock
                    x:Name="NodeKindText"
                    HorizontalAlignment="Right"
                    FontWeight="SemiBold" />
                <TextBlock
                    x:Name="SaveStateText"
                    HorizontalAlignment="Right"
                    Opacity="0.72" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="24,8,24,28" Spacing="18">
                <InfoBar
                    x:Name="WindowModeInfoBar"
                    IsClosable="False"
                    IsOpen="True"
                    Message="{Binding [Node_IndependentDescription], Source={StaticResource Localization}}"
                    Severity="Informational"
                    Title="{Binding [Node_IndependentEditor], Source={StaticResource Localization}}" />

                <controls:SaveConflictBanner
                    x:Name="SaveConflictBanner"
                    ReloadRequested="OnReloadCanonicalRequested"
                    ReapplyRequested="OnReapplyCanonicalRequested"
                    RetryRequested="OnRetryAutosaveRequested" />

                <StackPanel Spacing="8">
                    <TextBlock
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{Binding [Node_Context], Source={StaticResource Localization}}" />
                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Opacity="0.66" Text="{Binding [Node_TaskScheme], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="TaskSchemeText" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Opacity="0.66" Text="{Binding [Node_SharedUsage], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="SharedUsageText" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>

                <Expander
                    Header="{Binding [Node_TechnicalIdentity], Source={StaticResource Localization}}"
                    IsExpanded="False">
                    <Grid Padding="0,8,0,0" ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Opacity="0.66" Text="{Binding [Node_NodeId], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="NodeIdentityText" Grid.Column="1" FontFamily="Consolas" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="1" Opacity="0.66" Text="{Binding [Node_WindowKey], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="WindowKeyText" Grid.Row="1" Grid.Column="1" FontFamily="Consolas" TextWrapping="Wrap" />
                    </Grid>
                </Expander>

                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <StackPanel Spacing="8">
                    <TextBlock
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="{Binding [Node_CanonicalDefinition], Source={StaticResource Localization}}" />
                    <Grid ColumnSpacing="16" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Opacity="0.66" Text="{Binding [Node_TechnicalStatus], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="TechnicalStatusText" Grid.Column="1" />
                        <TextBlock Grid.Row="1" Opacity="0.66" Text="{Binding [Node_SemanticRevision], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="SemanticRevisionText" Grid.Row="1" Grid.Column="1" />
                        <TextBlock Grid.Row="2" Opacity="0.66" Text="{Binding [Node_LayoutRevision], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="LayoutRevisionText" Grid.Row="2" Grid.Column="1" />
                        <TextBlock Grid.Row="3" Opacity="0.66" Text="{Binding [Common_Group], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="GroupText" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" />
                        <TextBlock Grid.Row="4" Opacity="0.66" Text="{Binding [Common_Tags], Source={StaticResource Localization}}" />
                        <TextBlock x:Name="TagsText" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>

                <ContentControl x:Name="EditorHost">
                    <InfoBar
                        IsClosable="False"
                        IsOpen="True"
                        Message="{Binding [Node_NoEditorDescription], Source={StaticResource Localization}}"
                        Severity="Informational"
                        Title="{Binding [Node_EditorSurface], Source={StaticResource Localization}}" />
                </ContentControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
