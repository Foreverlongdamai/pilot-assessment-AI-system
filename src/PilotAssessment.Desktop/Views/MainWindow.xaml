<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PilotAssessment.Desktop.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding [App_Name], Source={StaticResource Localization}}"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Loaded="OnRootLoaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Subtitle="{Binding [App_ExpertWorkspace], Source={StaticResource Localization}}"
            Title="{Binding [App_Name], Source={StaticResource Localization}}">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <CommandBar
            Grid.Row="1"
            DefaultLabelPosition="Right"
            IsDynamicOverflowEnabled="True"
            IsOpen="False">
            <CommandBar.Content>
                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <StackPanel Margin="12,0,16,0" Orientation="Horizontal" Spacing="20">
                        <StackPanel>
                            <TextBlock Opacity="0.65" Text="{Binding [Common_Project], Source={StaticResource Localization}}" />
                            <TextBlock Text="{x:Bind ViewModel.ProjectText, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Opacity="0.65" Text="{Binding [Common_Session], Source={StaticResource Localization}}" />
                            <TextBlock Text="{x:Bind ViewModel.SessionText, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Opacity="0.65" Text="{Binding [Common_TaskScheme], Source={StaticResource Localization}}" />
                            <TextBlock Text="{x:Bind ViewModel.SchemeText, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Opacity="0.65" Text="{Binding [Common_Backend], Source={StaticResource Localization}}" />
                            <TextBlock Text="{x:Bind ViewModel.BackendStatusText, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Opacity="0.65" Text="{Binding [Common_Autosave], Source={StaticResource Localization}}" />
                            <TextBlock Text="{x:Bind ViewModel.AutosaveStatusText, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Opacity="0.65" Text="{Binding [Common_Run], Source={StaticResource Localization}}" />
                            <TextBlock Text="{x:Bind ViewModel.RunStatusText, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </CommandBar.Content>
            <AppBarButton
                AutomationProperties.Name="{Binding [A11y_ReconnectBackend], Source={StaticResource Localization}}"
                Command="{x:Bind ViewModel.ReconnectCommand}"
                Label="{Binding [Common_Reconnect], Source={StaticResource Localization}}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE72C;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="{Binding [A11y_SwitchLanguage], Source={StaticResource Localization}}"
                Command="{x:Bind ViewModel.CycleLanguageCommand}"
                Label="{x:Bind ViewModel.LanguageText, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE774;" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="{Binding [A11y_SwitchTheme], Source={StaticResource Localization}}"
                Command="{x:Bind ViewModel.CycleThemeCommand}"
                Label="{x:Bind ViewModel.ThemeText, Mode=OneWay}">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE793;" />
                </AppBarButton.Icon>
            </AppBarButton>
        </CommandBar>

        <NavigationView
            x:Name="ShellNavigation"
            Grid.Row="2"
            AutomationProperties.Name="{Binding [A11y_MainNavigation], Source={StaticResource Localization}}"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="OnNavigationSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="ProjectItem"
                    Content="{Binding [Nav_Project], Source={StaticResource Localization}}"
                    IsEnabled="{x:Bind ViewModel.IsBackendReady, Mode=OneWay}"
                    Tag="project">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="{Binding [Nav_Sessions], Source={StaticResource Localization}}"
                    IsEnabled="{x:Bind ViewModel.CanUseDomainCommands, Mode=OneWay}"
                    Tag="session">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="{Binding [Nav_ModelStudio], Source={StaticResource Localization}}"
                    IsEnabled="{x:Bind ViewModel.IsBackendReady, Mode=OneWay}"
                    Tag="model">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE943;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="{Binding [Nav_Runs], Source={StaticResource Localization}}"
                    IsEnabled="{x:Bind ViewModel.CanUseDomainCommands, Mode=OneWay}"
                    Tag="runs">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE768;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="{Binding [Nav_Results], Source={StaticResource Localization}}"
                    IsEnabled="{x:Bind ViewModel.CanUseDomainCommands, Mode=OneWay}"
                    Tag="results">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="{Binding [Nav_Library], Source={StaticResource Localization}}"
                    IsEnabled="{x:Bind ViewModel.IsBackendReady, Mode=OneWay}"
                    Tag="library">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="{Binding [Nav_Diagnostics], Source={StaticResource Localization}}" Tag="diagnostics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
