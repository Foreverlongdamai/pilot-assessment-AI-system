<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="PilotAssessment.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="GraphRawInputNodeBrush" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="GraphEvidenceNodeBrush" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="GraphBnNodeBrush" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="GraphNodeForegroundBrush" Color="{ThemeResource SystemColorHighlightTextColor}" />
                    <SolidColorBrush x:Key="GraphExtractionEdgeBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                    <SolidColorBrush x:Key="GraphProbabilisticEdgeBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                    <SolidColorBrush x:Key="GraphInactiveEdgeBrush" Color="{ThemeResource SystemColorGrayTextColor}" />
                    <SolidColorBrush x:Key="GraphBlockedStatusBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                    <SolidColorBrush x:Key="GraphIncompleteStatusBrush" Color="{ThemeResource SystemColorHotlightColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="GraphRawInputNodeBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="GraphEvidenceNodeBrush" Color="#0D9488" />
            <SolidColorBrush x:Key="GraphBnNodeBrush" Color="#7C3AED" />
            <SolidColorBrush x:Key="GraphNodeForegroundBrush" Color="White" />
            <SolidColorBrush x:Key="GraphExtractionEdgeBrush" Color="#0D9488" />
            <SolidColorBrush x:Key="GraphProbabilisticEdgeBrush" Color="#7C3AED" />
            <SolidColorBrush x:Key="GraphInactiveEdgeBrush" Color="#6B7280" />
            <SolidColorBrush x:Key="GraphBlockedStatusBrush" Color="#DC2626" />
            <SolidColorBrush x:Key="GraphIncompleteStatusBrush" Color="#F59E0B" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
