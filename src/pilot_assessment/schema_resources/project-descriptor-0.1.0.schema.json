{
  "$id": "urn:cranfield:pilot-assessment:schema:project-descriptor:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_id": {
      "const": "project-descriptor",
      "default": "project-descriptor",
      "title": "Contract Id",
      "type": "string"
    },
    "contract_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "format_version": {
      "const": "0.1.0",
      "title": "Format Version",
      "type": "string"
    },
    "name": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "project_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Project Id",
      "type": "string"
    }
  },
  "required": [
    "project_id",
    "format_version",
    "name",
    "created_at"
  ],
  "title": "Pilot Assessment Project Descriptor 0.1.0",
  "type": "object",
  "x-contract-version": "0.1.0",
  "x-runtime-invariants": [
    "project identity is portable and does not contain an absolute storage path"
  ]
}
