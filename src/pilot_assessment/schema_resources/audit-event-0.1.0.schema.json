{
  "$defs": {
    "JsonValue": {}
  },
  "$id": "urn:cranfield:pilot-assessment:schema:audit-event:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actor_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Actor Id",
      "type": "string"
    },
    "audit_event_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Audit Event Id",
      "type": "string"
    },
    "contract_id": {
      "const": "audit-event",
      "default": "audit-event",
      "title": "Contract Id",
      "type": "string"
    },
    "contract_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "details": {
      "additionalProperties": {
        "$ref": "#/$defs/JsonValue"
      },
      "title": "Details",
      "type": "object"
    },
    "event_type": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Event Type",
      "type": "string"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "subject_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Subject Id",
      "type": "string"
    },
    "subject_kind": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Subject Kind",
      "type": "string"
    },
    "transaction_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Transaction Id"
    }
  },
  "required": [
    "audit_event_id",
    "event_type",
    "actor_id",
    "occurred_at",
    "subject_kind",
    "subject_id",
    "transaction_id",
    "details"
  ],
  "title": "Pilot Assessment Audit Event 0.1.0",
  "type": "object",
  "x-contract-version": "0.1.0",
  "x-runtime-invariants": [
    "audit events are immutable metadata and do not embed managed payload bytes"
  ]
}
