{
  "$defs": {
    "SessionLifecycle": {
      "enum": [
        "active",
        "archived"
      ],
      "title": "SessionLifecycle",
      "type": "string"
    }
  },
  "$id": "urn:cranfield:pilot-assessment:schema:session-record:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_id": {
      "const": "session-record",
      "default": "session-record",
      "title": "Contract Id",
      "type": "string"
    },
    "contract_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "current_session_revision_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Current Session Revision Id",
      "type": "string"
    },
    "lifecycle": {
      "$ref": "#/$defs/SessionLifecycle"
    },
    "participant_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Participant Id",
      "type": "string"
    },
    "project_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Project Id",
      "type": "string"
    },
    "session_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Session Id",
      "type": "string"
    }
  },
  "required": [
    "session_id",
    "project_id",
    "participant_id",
    "lifecycle",
    "current_session_revision_id",
    "created_at"
  ],
  "title": "Pilot Assessment Session Record 0.1.0",
  "type": "object",
  "x-contract-version": "0.1.0",
  "x-runtime-invariants": [
    "a session points to one exact current managed revision"
  ]
}
