{
  "$defs": {
    "ComponentIdRef": {
      "additionalProperties": false,
      "description": "An internal exact ID reference without a recursive content hash.",
      "properties": {
        "kind": {
          "$ref": "#/$defs/ComponentKind"
        },
        "version_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Version Id",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "version_id"
      ],
      "title": "ComponentIdRef",
      "type": "object"
    },
    "ComponentKind": {
      "enum": [
        "evidence_concept",
        "evidence_version",
        "bn_node_concept",
        "bn_node_version",
        "evidence_binding_version",
        "cpt_version",
        "task_profile_version",
        "coverage_reporting_policy_version",
        "layout_version",
        "assessment_scheme_version",
        "source_descriptor"
      ],
      "title": "ComponentKind",
      "type": "string"
    },
    "InferenceVariable": {
      "additionalProperties": false,
      "properties": {
        "cpt_ref": {
          "$ref": "#/$defs/PinnedComponentRef"
        },
        "ordered_parent_ids": {
          "items": {
            "$ref": "#/$defs/ComponentIdRef"
          },
          "title": "Ordered Parent Ids",
          "type": "array"
        },
        "ordered_states": {
          "items": {
            "$ref": "#/$defs/VariableState"
          },
          "minItems": 2,
          "title": "Ordered States",
          "type": "array"
        },
        "variable_id": {
          "$ref": "#/$defs/ComponentIdRef"
        }
      },
      "required": [
        "variable_id",
        "ordered_states",
        "ordered_parent_ids",
        "cpt_ref"
      ],
      "title": "InferenceVariable",
      "type": "object"
    },
    "PinnedComponentRef": {
      "additionalProperties": false,
      "description": "An external replay pin binding an exact ID to its canonical content.",
      "properties": {
        "content_hash": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[0-9A-Fa-f]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ComponentKind"
        },
        "version_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Version Id",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "version_id",
        "content_hash"
      ],
      "title": "PinnedComponentRef",
      "type": "object"
    },
    "VariableState": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "maxLength": 8000,
          "title": "Description",
          "type": "string"
        },
        "label": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "state_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "State Id",
          "type": "string"
        }
      },
      "required": [
        "state_id",
        "label",
        "description"
      ],
      "title": "VariableState",
      "type": "object"
    }
  },
  "$id": "urn:cranfield:pilot-assessment:schema:inference-plan:0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "component_refs": {
      "items": {
        "$ref": "#/$defs/PinnedComponentRef"
      },
      "title": "Component Refs",
      "type": "array"
    },
    "contract_id": {
      "const": "inference-plan",
      "default": "inference-plan",
      "title": "Contract Id",
      "type": "string"
    },
    "contract_version": {
      "const": "0.1.0",
      "default": "0.1.0",
      "title": "Contract Version",
      "type": "string"
    },
    "plan_hash": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[0-9A-Fa-f]{64}$",
      "title": "Plan Hash",
      "type": "string"
    },
    "plan_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "title": "Plan Id",
      "type": "string"
    },
    "queryable_variable_ids": {
      "items": {
        "$ref": "#/$defs/ComponentIdRef"
      },
      "title": "Queryable Variable Ids",
      "type": "array"
    },
    "scheme_ref": {
      "$ref": "#/$defs/PinnedComponentRef"
    },
    "variables": {
      "items": {
        "$ref": "#/$defs/InferenceVariable"
      },
      "minItems": 1,
      "title": "Variables",
      "type": "array"
    }
  },
  "required": [
    "plan_id",
    "scheme_ref",
    "variables",
    "queryable_variable_ids",
    "component_refs",
    "plan_hash"
  ],
  "title": "Pilot Assessment Inference Plan 0.1.0",
  "type": "object",
  "x-contract-version": "0.1.0",
  "x-runtime-invariants": [
    "variables, state order, CPT pins, and scheme identity are exact"
  ]
}
