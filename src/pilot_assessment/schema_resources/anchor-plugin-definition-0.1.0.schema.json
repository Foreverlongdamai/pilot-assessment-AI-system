          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Dependency Id",
          "type": "string"
        },
        "expected_artifact_kind": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Artifact Kind"
        },
        "expected_schema_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Schema Id"
        },
        "kind": {
          "$ref": "#/$defs/DependencyKind"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "target_anchor_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Anchor Id"
        },
        "target_resource_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Resource Id"
        }
      },
      "required": [
        "dependency_id",
        "kind",
        "required"
      ],
      "title": "AnchorDependency",
      "type": "object"
    },
    "CoreModality": {
      "description": "Modalities that every v0.x manifest must explicitly describe.",
      "enum": [
        "X",
        "U",
        "I",
        "G",
        "EEG",
        "ECG",
        "pilot_camera"
