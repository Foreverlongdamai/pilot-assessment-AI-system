          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "title": "Kind",
          "type": "string"
        },
        "payload_kind": {
          "enum": [
            "table",
            "blob"
          ],
          "title": "Payload Kind",
          "type": "string"
        },
        "schema_descriptor": {
          "patternProperties": {
            "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$": {
              "$ref": "#/$defs/JsonValue"
            }
